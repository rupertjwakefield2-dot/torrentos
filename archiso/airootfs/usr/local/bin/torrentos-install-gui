#!/usr/bin/env python3
"""TorrentOS Install — GTK4/libadwaita guided installer launcher.

Presents a warning screen with disk info, then opens the archinstall TUI
in a Ghostty terminal window.
"""

import gi
import subprocess
import sys
import shutil

gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gtk, Adw, GLib, Pango


def _get_disks() -> list[dict]:
    """Return list of available block devices (disks only)."""
    disks = []
    try:
        result = subprocess.run(
            ["lsblk", "-J", "-o", "NAME,SIZE,MODEL,TYPE,MOUNTPOINTS"],
            capture_output=True, text=True, timeout=5,
        )
        import json
        data = json.loads(result.stdout)
        for dev in data.get("blockdevices", []):
            if dev.get("type") == "disk":
                name = dev.get("name", "")
                size = dev.get("size", "?")
                model = (dev.get("model") or "").strip() or "Unknown device"
                disks.append({"name": name, "size": size, "model": model})
    except Exception:
        pass
    return disks


def _check_internet() -> bool:
    try:
        r = subprocess.run(
            ["curl", "-s", "--max-time", "4", "https://archlinux.org"],
            capture_output=True, timeout=6,
        )
        return r.returncode == 0
    except Exception:
        return False


def _launch_terminal(cmd: list[str]) -> None:
    for term in [
        ["ghostty", "-e"] + cmd,
        ["foot",    "-e"] + cmd,
        ["xterm",   "-e"] + cmd,
    ]:
        if shutil.which(term[0]):
            subprocess.Popen(term)
            return
    # Last resort: run directly
    subprocess.Popen(cmd)


class InstallerWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Install TorrentOS")
        self.set_default_size(520, 1)
        self.set_resizable(False)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.set_content(box)

        header = Adw.HeaderBar()
        header.set_show_end_title_buttons(False)
        box.append(header)

        content = Gtk.Box(
            orientation=Gtk.Orientation.VERTICAL,
            spacing=20,
            margin_top=24, margin_bottom=24,
            margin_start=24, margin_end=24,
        )
        box.append(content)

        # ── Icon + title ─────────────────────────────────────────────────────
        icon = Gtk.Image.new_from_icon_name("drive-harddisk-system-symbolic")
        icon.set_pixel_size(64)
        icon.add_css_class("warning")
        content.append(icon)

        title = Gtk.Label(label="<b>Install TorrentOS to Disk</b>")
        title.set_use_markup(True)
        title.add_css_class("title-2")
        content.append(title)

        body = Gtk.Label(
            wrap=True,
            justify=Gtk.Justification.CENTER,
            label=(
                "This will permanently erase the disk you choose and "
                "install TorrentOS.\n\n"
                "Back up any important data before continuing. "
                "An internet connection is required."
            ),
        )
        body.set_wrap(True)
        content.append(body)

        # ── Internet status ──────────────────────────────────────────────────
        self._net_row = Adw.ActionRow()
        self._net_row.set_title("Internet connection")
        self._net_icon = Gtk.Image.new_from_icon_name("network-offline-symbolic")
        self._net_icon.set_pixel_size(20)
        self._net_row.add_prefix(self._net_icon)
        self._net_row.set_subtitle("Checking…")
        content.append(self._net_row)
        GLib.idle_add(self._check_net)

        # ── Disk list ────────────────────────────────────────────────────────
        disk_group = Adw.PreferencesGroup()
        disk_group.set_title("Detected disks")
        disk_group.set_description("archinstall will let you pick which disk to use")
        content.append(disk_group)

        disks = _get_disks()
        if disks:
            for d in disks:
                row = Adw.ActionRow()
                row.set_title(f"/dev/{d['name']}  —  {d['size']}")
                row.set_subtitle(d["model"])
                disk_icon = Gtk.Image.new_from_icon_name("drive-harddisk-symbolic")
                disk_icon.set_pixel_size(20)
                row.add_prefix(disk_icon)
                disk_group.add(row)
        else:
            row = Adw.ActionRow()
            row.set_title("No disks detected")
            row.set_subtitle("Run lsblk in a terminal to check")
            disk_group.add(row)

        # ── Warning banner ────────────────────────────────────────────────────
        warn = Adw.Banner()
        warn.set_title("All data on the selected disk will be erased.")
        warn.set_revealed(True)
        warn.add_css_class("error")
        content.append(warn)

        # ── Buttons ───────────────────────────────────────────────────────────
        btn_box = Gtk.Box(spacing=12, halign=Gtk.Align.CENTER, margin_top=4)
        content.append(btn_box)

        cancel = Gtk.Button(label="Cancel")
        cancel.connect("clicked", lambda _: app.quit())
        btn_box.append(cancel)

        self._install_btn = Gtk.Button(label="Begin Installation")
        self._install_btn.add_css_class("destructive-action")
        self._install_btn.connect("clicked", self._launch_installer)
        btn_box.append(self._install_btn)

        self.present()

    def _check_net(self):
        ok = _check_internet()
        if ok:
            self._net_icon.set_from_icon_name("network-transmit-receive-symbolic")
            self._net_row.set_subtitle("Connected")
            self._net_row.add_css_class("success")
        else:
            self._net_icon.set_from_icon_name("network-offline-symbolic")
            self._net_row.set_subtitle("No internet — packages cannot be downloaded")
            self._net_row.add_css_class("error")

    def _launch_installer(self, _btn):
        self._install_btn.set_label("Launching…")
        self._install_btn.set_sensitive(False)
        _launch_terminal(["sudo", "torrentos-install"])
        GLib.timeout_add(1200, self.close)


class InstallerApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.torrentos.Install")
        self.connect("activate", self._activate)

    def _activate(self, app):
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        InstallerWindow(app)


if __name__ == "__main__":
    app = InstallerApp()
    sys.exit(app.run(sys.argv))
