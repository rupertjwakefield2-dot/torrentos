#!/bin/bash
# TorrentOS first-boot setup wizard
# Runs once on first Hyprland start to configure keyboard layout and timezone.

DONE_FLAG="$HOME/.config/torrentos/.firstboot-done"
USER_CONF="$HOME/.config/hypr/user.conf"

[ -f "$DONE_FLAG" ] && exit 0

mkdir -p "$HOME/.config/torrentos"
mkdir -p "$HOME/.config/hypr"
touch "$USER_CONF" 2>/dev/null

clear
echo ""
echo "  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó"
echo "     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ"
echo "     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó"
echo "     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ"
echo "     ‚Ėą‚Ėą‚ēĎ   ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ"
echo "     ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ"
echo ""
echo "  Welcome to TorrentOS v0.4  -  riptide"
echo "  -----------------------------------------------------------------------"
echo ""
echo "  Let's get you set up. This will only take a moment."
echo ""

# Keyboard layout
echo "  Keyboard layout"
echo "  -----------------------------------------------------------------------"
echo ""
echo "   1) United Kingdom (gb)     6) Italian (it)"
echo "   2) United States (us)      7) Portuguese (pt)"
echo "   3) German (de)             8) Dutch (nl)"
echo "   4) French (fr)             9) Swedish (se)"
echo "   5) Spanish (es)           10) Other (type manually)"
echo ""
printf "  Your choice [1]: "
read -r KB_CHOICE

case "$KB_CHOICE" in
    2)  KB="us" ;;
    3)  KB="de" ;;
    4)  KB="fr" ;;
    5)  KB="es" ;;
    6)  KB="it" ;;
    7)  KB="pt" ;;
    8)  KB="nl" ;;
    9)  KB="se" ;;
    10) printf "  Layout code (e.g. pl, ru, jp): "; read -r KB; KB="${KB:-us}" ;;
    *)  KB="gb" ;;
esac

echo ""
echo "  Keyboard set to: $KB"
localectl set-keymap "$KB" 2>/dev/null || true

# Timezone
echo ""
echo "  Timezone"
echo "  -----------------------------------------------------------------------"
echo ""
echo "   1) London (Europe/London)     5) Berlin (Europe/Berlin)"
echo "   2) New York (America/New_York) 6) Paris (Europe/Paris)"
echo "   3) Los Angeles (America/LA)   7) Tokyo (Asia/Tokyo)"
echo "   4) Chicago (America/Chicago)  8) Sydney (Australia/Sydney)"
echo "   9) Other (type manually)"
echo ""
printf "  Your choice [1]: "
read -r TZ_CHOICE

case "$TZ_CHOICE" in
    2)  TZ="America/New_York" ;;
    3)  TZ="America/Los_Angeles" ;;
    4)  TZ="America/Chicago" ;;
    5)  TZ="Europe/Berlin" ;;
    6)  TZ="Europe/Paris" ;;
    7)  TZ="Asia/Tokyo" ;;
    8)  TZ="Australia/Sydney" ;;
    9)  printf "  Timezone (e.g. Europe/Warsaw): "; read -r TZ; TZ="${TZ:-Europe/London}" ;;
    *)  TZ="Europe/London" ;;
esac

echo ""
echo "  Timezone set to: $TZ"
timedatectl set-timezone "$TZ" 2>/dev/null || ln -sf "/usr/share/zoneinfo/$TZ" /etc/localtime 2>/dev/null || true

# Write user.conf
{
    echo "# TorrentOS user config - generated by first-boot setup"
    echo "# Edit this file to customise your desktop."
    echo ""
    echo "input {"
    echo "    kb_layout = $KB"
    echo "}"
} > "$USER_CONF"

touch "$DONE_FLAG"

echo ""
echo "  -----------------------------------------------------------------------"
echo "  All done. Starting the desktop now..."
echo ""
sleep 1
