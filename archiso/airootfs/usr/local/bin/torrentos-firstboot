#!/usr/bin/env bash
# TorrentOS first-boot setup wizard
# Runs once on first Hyprland start; tries the GTK wizard first, then this TUI.

DONE_FLAG="$HOME/.config/torrentos/.firstboot-done"
USER_CONF="$HOME/.config/hypr/user.conf"
VERSION="$(grep '^TORRENTOS_VERSION=' /etc/torrentos/version 2>/dev/null | cut -d= -f2 | tr -d '"' || echo 0.4)"

# в”Ђв”Ђ Try the GTK wizard first в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if command -v torrentos-first-boot-wizard >/dev/null 2>&1; then
    torrentos-first-boot-wizard
    exit 0
fi

# в”Ђв”Ђ Already completed? в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
[ -f "$DONE_FLAG" ] && exit 0

mkdir -p "$HOME/.config/torrentos" "$HOME/.config/hypr"
touch "$USER_CONF" 2>/dev/null

# в”Ђв”Ђ Restore terminal to a sane state в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# agetty autologin and localectl can both scramble stty settings; reset before
# every section so backspace/Ctrl+C always work.
fix_stty() {
    stty sane              2>/dev/null || true
    stty erase $'\177'     2>/dev/null || true   # DEL (127) = backspace
    stty icrnl intr $'\003' 2>/dev/null || true
    # If TERM is unset or "unknown", fall back to "linux" so ncurses tools work.
    [[ -z "${TERM:-}" || "$TERM" == "unknown" ]] && export TERM=linux
}
fix_stty

# в”Ђв”Ђ Detect whiptail / dialog for mouse-capable menus в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MENU_CMD=""
command -v whiptail >/dev/null 2>&1 && MENU_CMD="whiptail"
command -v dialog   >/dev/null 2>&1 && MENU_CMD="${MENU_CMD:-dialog}"

# в”Ђв”Ђ Colours в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
B='\033[38;2;30;111;255m'
C='\033[38;2;91;192;235m'
W='\033[1;37m'
D='\033[2;37m'
G='\033[38;2;91;235;161m'
Y='\033[38;2;255;180;84m'
N='\033[0m'
HR="${D}  в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${N}"

# в”Ђв”Ђ Prompt helper вЂ” always restores stty first в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ask() {
    # ask <varname> <prompt> [default]
    # NOTE: deliberately uses 'read -r' (no -e) so backspace is handled by the
    # kernel line discipline (stty erase=^?) rather than readline. readline
    # breaks in unknown/dumb terminal types (live ISO agetty sessions).
    local __var="$1" __prompt="$2" __default="${3:-}"
    fix_stty
    if [[ -n "$__default" ]]; then
        printf "${W}  ${__prompt} [${__default}]: ${N}"
    else
        printf "${W}  ${__prompt}: ${N}"
    fi
    IFS= read -r __reply
    [[ -z "$__reply" ]] && __reply="$__default"
    printf -v "$__var" '%s' "$__reply"
}

# в”Ђв”Ђ whiptail menu helper в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# wt_menu <varname> <title> <prompt> <item1> <desc1> [<item2> <desc2> ...]
wt_menu() {
    local __var="$1"; shift
    local __title="$1"; shift
    local __prompt="$1"; shift
    local __items=("$@")
    local __result
    __result=$("$MENU_CMD" --title "$__title" --menu "$__prompt" 18 60 10 \
        "${__items[@]}" 3>&1 1>&2 2>&3)
    fix_stty
    printf -v "$__var" '%s' "$__result"
}

# в”Ђв”Ђ Header в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
clear
echo
printf "${B}"
cat <<'LOGO'
  в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в•—   в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—
     в–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в–€в–€в•—  в–€в–€в•‘в•љв•ђв•ђв–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ
     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в•—  в–€в–€в•”в–€в–€в•— в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—
     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•‘в•љв–€в–€в•—в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в•љв•ђв•ђв•ђв•ђв–€в–€в•‘
     в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘  в–€в–€в•‘в–€в–€в•‘  в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘ в•љв–€в–€в–€в–€в•‘   в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•‘
     в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ђв•ђв•ќ   в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќ
LOGO
printf "${N}"
echo
printf "${D}  Welcome to TorrentOS v${VERSION} В· riptide${N}\n"
printf "$HR\n"
echo
printf "${D}  Let's get you set up. This takes about a minute.${N}\n"
echo

# в”Ђв”Ђ 1. Keyboard layout в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${C}  Step 1 of 4 вЂ” Keyboard layout${N}\n"
printf "$HR\n\n"

if [[ -n "$MENU_CMD" ]]; then
    wt_menu KB_CHOICE "Keyboard Layout" "Choose your keyboard layout:" \
        "gb" "United Kingdom" \
        "us" "United States" \
        "de" "German" \
        "fr" "French" \
        "es" "Spanish" \
        "it" "Italian" \
        "pt" "Portuguese" \
        "nl" "Dutch" \
        "se" "Swedish" \
        "other" "Other (type manually)"
    clear
    [[ -z "$KB_CHOICE" ]] && KB_CHOICE="gb"
    KB="$KB_CHOICE"
    if [[ "$KB" == "other" ]]; then
        ask KB "Layout code (e.g. pl, ru, jp)" "us"
    fi
else
    printf "${D}   1) United Kingdom (gb)   ${N}  ${D}6) Italian (it)${N}\n"
    printf "${D}   2) United States (us)    ${N}  ${D}7) Portuguese (pt)${N}\n"
    printf "${D}   3) German (de)           ${N}  ${D}8) Dutch (nl)${N}\n"
    printf "${D}   4) French (fr)           ${N}  ${D}9) Swedish (se)${N}\n"
    printf "${D}   5) Spanish (es)          ${N}  ${D}10) Other (type manually)${N}\n\n"
    ask KB_CHOICE "Your choice" "1"
    case "$KB_CHOICE" in
        2) KB="us" ;; 3) KB="de" ;; 4) KB="fr" ;; 5) KB="es" ;;
        6) KB="it" ;; 7) KB="pt" ;; 8) KB="nl" ;; 9) KB="se" ;;
        10) ask KB "Layout code (e.g. pl, ru, jp)" "us" ;;
        *) KB="gb" ;;
    esac
fi

printf "${G}  вњ”  Keyboard: ${W}${KB}${N}\n"
localectl set-keymap "$KB" 2>/dev/null || true
fix_stty   # localectl can reset terminal settings вЂ” restore immediately

# в”Ђв”Ђ 2. Timezone в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo
printf "${C}  Step 2 of 4 вЂ” Timezone${N}\n"
printf "$HR\n\n"

if [[ -n "$MENU_CMD" ]]; then
    wt_menu TZ_CHOICE "Timezone" "Choose your timezone:" \
        "Europe/London"       "London (UTC+0/+1)" \
        "America/New_York"    "New York (EST/EDT)" \
        "America/Los_Angeles" "Los Angeles (PST/PDT)" \
        "America/Chicago"     "Chicago (CST/CDT)" \
        "Europe/Berlin"       "Berlin (CET/CEST)" \
        "Europe/Paris"        "Paris (CET/CEST)" \
        "Europe/Madrid"       "Madrid (CET/CEST)" \
        "Europe/Amsterdam"    "Amsterdam (CET/CEST)" \
        "Europe/Warsaw"       "Warsaw (CET/CEST)" \
        "Europe/Rome"         "Rome (CET/CEST)" \
        "Europe/Athens"       "Athens (EET/EEST)" \
        "Europe/Istanbul"     "Istanbul (TRT)" \
        "America/Toronto"     "Toronto (EST/EDT)" \
        "America/Vancouver"   "Vancouver (PST/PDT)" \
        "America/Sao_Paulo"   "SГЈo Paulo (BRT)" \
        "America/Mexico_City" "Mexico City (CST/CDT)" \
        "Asia/Tokyo"          "Tokyo (JST)" \
        "Asia/Shanghai"       "Shanghai/Beijing (CST)" \
        "Asia/Kolkata"        "India (IST)" \
        "Asia/Dubai"          "Dubai (GST)" \
        "Asia/Singapore"      "Singapore (SGT)" \
        "Asia/Seoul"          "Seoul (KST)" \
        "Australia/Sydney"    "Sydney (AEST/AEDT)" \
        "Australia/Melbourne" "Melbourne (AEST/AEDT)" \
        "Pacific/Auckland"    "Auckland (NZST/NZDT)" \
        "Africa/Johannesburg" "Johannesburg (SAST)" \
        "Africa/Lagos"        "Lagos/West Africa (WAT)" \
        "other"               "Other (type manually)"
    clear
    [[ -z "$TZ_CHOICE" ]] && TZ_CHOICE="Europe/London"
    TZ="$TZ_CHOICE"
    if [[ "$TZ" == "other" ]]; then
        ask TZ "Timezone (e.g. Europe/Warsaw)" "Europe/London"
    fi
else
    printf "${D}   1) London  (Europe/London)         ${N}  ${D}6) Paris (Europe/Paris)${N}\n"
    printf "${D}   2) New York (America/New_York)      ${N}  ${D}7) Tokyo (Asia/Tokyo)${N}\n"
    printf "${D}   3) LA      (America/Los_Angeles)    ${N}  ${D}8) Sydney (Australia/Sydney)${N}\n"
    printf "${D}   4) Chicago (America/Chicago)        ${N}  ${D}9) Dubai (Asia/Dubai)${N}\n"
    printf "${D}   5) Berlin  (Europe/Berlin)          ${N}  ${D}10) Other (type manually)${N}\n\n"
    fix_stty   # ensure backspace works for this read
    ask TZ_CHOICE "Your choice" "1"
    case "$TZ_CHOICE" in
        2)  TZ="America/New_York"    ;; 3)  TZ="America/Los_Angeles" ;;
        4)  TZ="America/Chicago"     ;; 5)  TZ="Europe/Berlin"       ;;
        6)  TZ="Europe/Paris"        ;; 7)  TZ="Asia/Tokyo"          ;;
        8)  TZ="Australia/Sydney"    ;; 9)  TZ="Asia/Dubai"          ;;
        10) fix_stty; ask TZ "Timezone (e.g. Europe/Warsaw)" "Europe/London" ;;
        *) TZ="Europe/London" ;;
    esac
fi

printf "${G}  вњ”  Timezone: ${W}${TZ}${N}\n"
timedatectl set-timezone "$TZ" 2>/dev/null \
    || ln -sf "/usr/share/zoneinfo/$TZ" /etc/localtime 2>/dev/null \
    || true

# в”Ђв”Ђ 3. Locale / language в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo
printf "${C}  Step 3 of 4 вЂ” System language${N}\n"
printf "$HR\n\n"

if [[ -n "$MENU_CMD" ]]; then
    wt_menu LOCALE_CHOICE "System Language" "Choose your language/locale:" \
        "en_GB.UTF-8" "English (United Kingdom)" \
        "en_US.UTF-8" "English (United States)" \
        "de_DE.UTF-8" "German (Deutsch)" \
        "fr_FR.UTF-8" "French (FranГ§ais)" \
        "es_ES.UTF-8" "Spanish (EspaГ±ol)" \
        "it_IT.UTF-8" "Italian (Italiano)" \
        "pt_PT.UTF-8" "Portuguese (Portugal)" \
        "pt_BR.UTF-8" "Portuguese (Brazil)" \
        "nl_NL.UTF-8" "Dutch (Nederlands)" \
        "pl_PL.UTF-8" "Polish (Polski)" \
        "ru_RU.UTF-8" "Russian (Р СѓСЃСЃРєРёР№)" \
        "ja_JP.UTF-8" "Japanese (ж—Ґжњ¬иЄћ)" \
        "zh_CN.UTF-8" "Chinese Simplified (дё­ж–‡)" \
        "ko_KR.UTF-8" "Korean (н•њкµ­м–ґ)" \
        "skip"        "Keep current locale"
    clear
    [[ -z "$LOCALE_CHOICE" ]] && LOCALE_CHOICE="en_GB.UTF-8"
    LOCALE="$LOCALE_CHOICE"
    [[ "$LOCALE" == "skip" ]] && LOCALE=""
else
    printf "${D}   1) English UK (en_GB.UTF-8)   ${N}  ${D}5) Spanish  (es_ES.UTF-8)${N}\n"
    printf "${D}   2) English US (en_US.UTF-8)   ${N}  ${D}6) Italian  (it_IT.UTF-8)${N}\n"
    printf "${D}   3) German     (de_DE.UTF-8)   ${N}  ${D}7) French   (fr_FR.UTF-8)${N}\n"
    printf "${D}   4) Portuguese (pt_PT.UTF-8)   ${N}  ${D}8) Keep current${N}\n\n"
    fix_stty
    ask LOCALE_CHOICE "Your choice" "1"
    case "$LOCALE_CHOICE" in
        2) LOCALE="en_US.UTF-8" ;; 3) LOCALE="de_DE.UTF-8" ;;
        4) LOCALE="pt_PT.UTF-8" ;; 5) LOCALE="es_ES.UTF-8" ;;
        6) LOCALE="it_IT.UTF-8" ;; 7) LOCALE="fr_FR.UTF-8" ;;
        8) LOCALE="" ;;
        *) LOCALE="en_GB.UTF-8" ;;
    esac
fi

if [[ -n "$LOCALE" ]]; then
    printf "${G}  вњ”  Locale: ${W}${LOCALE}${N}\n"
    localectl set-locale "LANG=$LOCALE" 2>/dev/null || true
else
    printf "${G}  вњ”  Locale unchanged.${N}\n"
fi

# в”Ђв”Ђ 4. Browser в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo
printf "${C}  Step 4 of 4 вЂ” Web browser${N}\n"
printf "$HR\n"
echo
printf "${D}  Chromium is already installed. Want to add another browser?${N}\n\n"

if [[ -n "$MENU_CMD" ]]; then
    wt_menu BR_CHOICE "Web Browser" "Add an additional browser (Chromium already installed):" \
        "chrome"  "Google Chrome   вЂ” syncs with your Google account" \
        "firefox" "Firefox         вЂ” fast, private, open-source" \
        "brave"   "Brave           вЂ” Chrome-based, built-in ad blocker" \
        "vivaldi" "Vivaldi         вЂ” highly customisable" \
        "skip"    "Skip            вЂ” Chromium is enough"
    clear
    [[ -z "$BR_CHOICE" ]] && BR_CHOICE="skip"
else
    printf "${D}   1) ${W}Google Chrome${D}   вЂ” syncs with your Google account${N}\n"
    printf "${D}   2) ${W}Firefox${D}          вЂ” fast, private, open-source${N}\n"
    printf "${D}   3) ${W}Brave${D}            вЂ” Chrome-based, built-in ad blocker${N}\n"
    printf "${D}   4) ${W}Vivaldi${D}          вЂ” highly customisable${N}\n"
    printf "${D}   5) ${W}Skip${D}             вЂ” Chromium is already included${N}\n\n"
    fix_stty
    ask BR_CHOICE "Your choice" "5"
    case "$BR_CHOICE" in
        1) BR_CHOICE="chrome"  ;;
        2) BR_CHOICE="firefox" ;;
        3) BR_CHOICE="brave"   ;;
        4) BR_CHOICE="vivaldi" ;;
        *) BR_CHOICE="skip"    ;;
    esac
fi

case "$BR_CHOICE" in
    chrome)  BROWSER_PKG="google-chrome"; BROWSER_NAME="Google Chrome"; BROWSER_SRC="aur"    ;;
    firefox) BROWSER_PKG="firefox";       BROWSER_NAME="Firefox";       BROWSER_SRC="pacman" ;;
    brave)   BROWSER_PKG="brave-bin";     BROWSER_NAME="Brave";         BROWSER_SRC="aur"    ;;
    vivaldi) BROWSER_PKG="vivaldi";       BROWSER_NAME="Vivaldi";       BROWSER_SRC="aur"    ;;
    *)       BROWSER_PKG="" ;;
esac

if [[ -n "$BROWSER_PKG" ]]; then
    printf "${G}  Installing ${W}${BROWSER_NAME}${G} вЂ” this may take a few minutesвЂ¦${N}\n"
    if [[ "$BROWSER_SRC" == "aur" ]]; then
        AUR=""
        command -v paru >/dev/null 2>&1 && AUR=paru
        command -v yay  >/dev/null 2>&1 && AUR="${AUR:-yay}"
        if [[ -n "$AUR" ]]; then
            "$AUR" -S --needed --noconfirm "$BROWSER_PKG" 2>/dev/null \
                && printf "${G}  вњ”  ${BROWSER_NAME} installed.${N}\n" \
                || printf "${Y}  вљ   Could not install right now. Run: paru -S ${BROWSER_PKG}${N}\n"
        else
            printf "${Y}  вљ   No AUR helper found. Run: ${W}torrentos-get-browser${Y} after setup.${N}\n"
        fi
    else
        sudo pacman -S --needed --noconfirm "$BROWSER_PKG" 2>/dev/null \
            && printf "${G}  вњ”  ${BROWSER_NAME} installed.${N}\n" \
            || printf "${Y}  вљ   Could not install right now. Run: ${W}torrentos-get-browser${Y} after setup.${N}\n"
    fi
else
    printf "${G}  вњ”  Chromium is ready to use.${N}\n"
fi

# в”Ђв”Ђ Set up Flathub (silent вЂ” runs in background while user reads done screen) в”Ђв”Ђ
_setup_flathub() {
    if command -v flatpak >/dev/null 2>&1; then
        if ! flatpak remotes 2>/dev/null | grep -q flathub; then
            flatpak remote-add --if-not-exists flathub \
                https://dl.flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true
        fi
    fi
}
_setup_flathub &

# в”Ђв”Ђ Create XDG user directories в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for dir in Desktop Downloads Documents Pictures Videos Music Public Templates; do
    mkdir -p "$HOME/$dir"
done
command -v xdg-user-dirs-update >/dev/null 2>&1 && xdg-user-dirs-update 2>/dev/null || true

# в”Ђв”Ђ Write user.conf в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
{
    echo "# TorrentOS user config вЂ” generated by first-boot wizard"
    echo "# Edit this file to customise your desktop."
    echo "# This file is sourced at the bottom of hyprland.conf."
    echo ""
    echo "input {"
    echo "    kb_layout = $KB"
    echo "}"
} > "$USER_CONF"

touch "$DONE_FLAG"

# в”Ђв”Ђ Done screen в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fix_stty
clear
echo
printf "${B}"
printf "  в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n"
printf "  в•‘      TorrentOS v${VERSION} is ready  рџЋ‰                  в•‘\n"
printf "  в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n"
printf "${N}\n"

