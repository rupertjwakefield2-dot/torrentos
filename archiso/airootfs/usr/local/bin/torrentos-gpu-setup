#!/usr/bin/env bash
# torrentos-gpu-setup — GPU-specific environment variable injection for Hyprland.
#
# Runs once at Hyprland startup (exec-once in hyprland.conf).
# Detects the primary GPU vendor and applies the appropriate Wayland env vars
# via hyprctl setenv so they don't pollute AMD/Intel sessions.
#
# NVIDIA-specific vars are only set when an NVIDIA GPU is present, preventing
# VA-API (LIBVA_DRIVER_NAME) and GBM (GBM_BACKEND) misconfiguration on AMD/Intel.

set -euo pipefail

_is_nvidia() {
    lspci 2>/dev/null | grep -qi nvidia && \
        lsmod 2>/dev/null | grep -q "^nvidia "
}

_is_amd() {
    lspci 2>/dev/null | grep -qiE "AMD|Radeon|AMDGPU"
}

_is_intel() {
    lspci 2>/dev/null | grep -qi "Intel.*Graphics\|Intel.*UHD\|Intel.*Iris"
}

# Wait for Hyprland socket to be ready (avoid race on very fast CPUs)
_wait_hyprland() {
    local rt="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    local deadline=$(( $(date +%s) + 10 ))
    while (( $(date +%s) < deadline )); do
        [[ -d "$rt/hypr" ]] && ls "$rt"/hypr/*/hyprland.lock >/dev/null 2>&1 && return 0
        sleep 0.5
    done
    return 1
}

_wait_hyprland || exit 0

if _is_nvidia; then
    # Set NVIDIA Wayland vars via hyprctl so they're available to all child processes
    hyprctl setenv LIBVA_DRIVER_NAME nvidia
    hyprctl setenv GBM_BACKEND nvidia-drm
    hyprctl setenv __GLX_VENDOR_LIBRARY_NAME nvidia
    hyprctl setenv NVD_BACKEND direct
    hyprctl setenv WLR_NO_HARDWARE_CURSORS 1   # legacy wlroots compat
    # Modern Hyprland cursor option — must be set at runtime since the config default
    # is false (hardware cursors enabled); NVIDIA needs software cursors on Wayland.
    hyprctl keyword cursor:no_hardware_cursors true
elif _is_amd; then
    hyprctl setenv LIBVA_DRIVER_NAME radeonsi
elif _is_intel; then
    hyprctl setenv LIBVA_DRIVER_NAME iHD
fi
