#!/usr/bin/env bash
#
# TorrentOS Disk Installer
# Wraps archinstall with TorrentOS defaults and a guided pre-flight check.
#
set -euo pipefail

RED='\033[1;31m'; GRN='\033[1;32m'; BLU='\033[1;34m'; YLW='\033[1;33m'; RST='\033[0m'
log()  { printf "${BLU}[install]${RST} %s\n" "$*"; }
ok()   { printf "${GRN}[  ok  ]${RST} %s\n" "$*"; }
warn() { printf "${YLW}[ warn ]${RST} %s\n" "$*"; }
err()  { printf "${RED}[ err  ]${RST} %s\n" "$*" >&2; }

cat << 'BANNER'

  ████████  ████████  ████████  ████████  ████████  ██████   ██████  ██████
     ██     ██     ██ ██     ██ ██     ██ ██        ██   ██ ██    ██ ██
     ██     ██     ██ ████████  ████████  ████      ██   ██ ██    ██ ███████
     ██     ██     ██ ██   ██   ██   ██   ██        ██   ██ ██    ██      ██
     ██      ████████ ██    ██  ██    ██  ████████  ██████   ██████  ███████

                     Install TorrentOS to Disk — v0.3.0

BANNER

# ── Pre-flight checks ────────────────────────────────────────────────────────

if [[ $EUID -ne 0 ]]; then
    err "This installer must run as root. Try: sudo torrentos-install"
    exit 1
fi

log "Checking internet connection..."
if curl -s --max-time 5 https://archlinux.org >/dev/null 2>&1; then
    ok "Internet reachable."
else
    warn "No internet detected. archinstall needs internet to download packages."
    echo -n "  Continue anyway? [y/N] "
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
fi

log "Available disks:"
lsblk -o NAME,SIZE,TYPE,MOUNTPOINTS | grep -E "disk|NAME"
echo

echo -e "${YLW}WARNING: Installation will ERASE the selected disk.${RST}"
echo -e "${YLW}         Back up any data before continuing.${RST}"
echo
echo -n "Ready to launch the installer? [y/N] "
read -r ans
[[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }

# ── Write archinstall config ─────────────────────────────────────────────────

CONF_DIR=$(mktemp -d /tmp/torrentos-install.XXXXX)
trap 'rm -rf "$CONF_DIR"' EXIT

# Pre-fill archinstall with TorrentOS defaults.
# User still picks the disk and username interactively.
cat > "$CONF_DIR/user_configuration.json" << 'JSON'
{
  "additional-repositories": [],
  "archinstall-language": "English",
  "bootloader": "Grub",
  "hostname": "torrentos",
  "kernels": ["linux"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "profile_config": {
    "profile": {
      "custom_settings": {},
      "details": ["Hyprland"],
      "main": "Desktop"
    },
    "gfx_driver": "All open-source (default)"
  },
  "swap": true,
  "timezone": "UTC"
}
JSON

# ── Launch archinstall ────────────────────────────────────────────────────────

log "Launching archinstall with TorrentOS defaults..."
echo

archinstall \
    --config "$CONF_DIR/user_configuration.json" \
    --silent

echo
ok "Installation complete! Remove the live media and reboot."
echo -e "   ${BLU}reboot${RST}"
