#!/usr/bin/env bash
#
# TorrentOS Disk Installer
# Wraps archinstall with TorrentOS defaults and a guided pre-flight check.
# Also copies the local TorrentOS package repo into the installed system so
# TorrentOS-specific packages (settings, tools, hyprland-config, etc.) are
# available on first boot.
#
set -euo pipefail

RED='\033[1;31m'; GRN='\033[1;32m'; BLU='\033[1;34m'; YLW='\033[1;33m'
CYN='\033[38;2;91;192;235m'; DIM='\033[2;37m'; RST='\033[0m'

log()  { printf "${BLU}[install]${RST} %s\n" "$*"; }
ok()   { printf "${GRN}[  ok  ]${RST} %s\n" "$*"; }
warn() { printf "${YLW}[ warn ]${RST} %s\n" "$*"; }
err()  { printf "${RED}[ err  ]${RST} %s\n" "$*" >&2; }
step() { printf "\n${CYN}  в–ё %s${RST}\n" "$*"; }

_ver="$(grep '^TORRENTOS_VERSION=' /etc/torrentos/version 2>/dev/null | cut -d= -f2 | tr -d '"' || echo 0.5)"

printf "${BLU}"
cat <<'LOGO'

  в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в•—   в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—
     в–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в–€в–€в•—  в–€в–€в•‘в•љв•ђв•ђв–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ
     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в•—  в–€в–€в•”в–€в–€в•— в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—
     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•‘в•љв–€в–€в•—в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в•љв•ђв•ђв•ђв•ђв–€в–€в•‘
     в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘  в–€в–€в•‘в–€в–€в•‘  в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘ в•љв–€в–€в–€в–€в•‘   в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•‘
     в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ђв•ђв•ќ   в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќ

LOGO
printf "${RST}"
printf "${DIM}                     Install TorrentOS to Disk вЂ” v${_ver}${RST}\n\n"

# в”Ђв”Ђ Pre-flight checks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if [[ $EUID -ne 0 ]]; then
    err "This installer must run as root. Try: sudo torrentos-install"
    exit 1
fi

step "Checking prerequisites"

# Check archinstall is available
if ! command -v archinstall >/dev/null 2>&1; then
    err "archinstall not found. Install it with: sudo pacman -S archinstall"
    exit 1
fi

# Check jq (needed to build JSON config)
if ! command -v jq >/dev/null 2>&1; then
    err "jq not found. Install it with: sudo pacman -S jq"
    exit 1
fi

log "Checking internet connection..."
if curl -s --max-time 5 https://archlinux.org >/dev/null 2>&1; then
    ok "Internet reachable."
elif curl -s --max-time 5 https://1.1.1.1 >/dev/null 2>&1; then
    ok "Internet reachable (via IP)."
else
    warn "No internet detected. archinstall needs internet to download packages."
    warn "Connect via WiFi first:  nmtui"
    echo
    printf "  Continue anyway? [y/N] "
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
fi

# Check UEFI vs BIOS
if [[ -d /sys/firmware/efi ]]; then
    ok "UEFI firmware detected вЂ” GRUB with EFI will be used."
    BOOT_MODE="uefi"
else
    ok "Legacy BIOS detected вЂ” GRUB with MBR will be used."
    BOOT_MODE="bios"
fi

# Detect NVIDIA GPU
NVIDIA_DETECTED=false
if lspci 2>/dev/null | grep -qi nvidia; then
    NVIDIA_DETECTED=true
    ok "NVIDIA GPU detected вЂ” nvidia-dkms will be installed."
fi

step "Available block devices"
lsblk -o NAME,SIZE,MODEL,TYPE,MOUNTPOINTS -e 7,11 | grep -v "^loop"
echo

printf "${YLW}  вљ   WARNING: Installation will PERMANENTLY ERASE the selected disk.${RST}\n"
printf "${YLW}     Back up all important data before continuing.${RST}\n"
echo
printf "  Ready to launch the guided installer? [y/N] "
read -r ans
[[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }

# в”Ђв”Ђ Locate local TorrentOS repo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
step "Locating local TorrentOS package repo"
LOCAL_REPO=""
for candidate in \
    "/run/archiso/bootmnt/repo/x86_64" \
    "/run/archiso/airootfs/repo/x86_64" \
    "/repo/x86_64" \
    "/opt/torrentos-repo/x86_64"
do
    if [[ -d "$candidate" ]] && ls "$candidate"/torrentos.db* >/dev/null 2>&1; then
        LOCAL_REPO="$candidate"
        break
    fi
done

# в”Ђв”Ђ Write archinstall config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CONF_DIR=$(mktemp -d /tmp/torrentos-install.XXXXX)
trap 'rm -rf "$CONF_DIR"' EXIT

# Additional packages to install on the new system (on top of Desktop/Hyprland)
EXTRA_PACKAGES=(
    # TorrentOS custom packages
    torrentos-base
    torrentos-theme
    torrentos-hyprland-config
    torrentos-first-boot
    torrentos-settings
    torrentos-tools
    # Python deps for settings app
    python
    python-gobject
    python-tomli-w
    # Fonts
    inter-font
    ttf-jetbrains-mono-nerd
    noto-fonts
    noto-fonts-emoji
    # System utils
    libnotify
    pacman-contrib
    papirus-icon-theme
    # Terminal & shell
    ghostty
    zsh
    zsh-completions
    starship
    btop
    htop
    bat
    eza
    fzf
    zoxide
    ripgrep
    fd
    tmux
    fastfetch
    # Desktop components
    waybar
    swaync
    rofi-wayland
    hyprpaper
    hypridle
    hyprlock
    hyprpicker
    nwg-dock-hyprland
    # Media
    playerctl
    pavucontrol
    pipewire
    pipewire-pulse
    pipewire-alsa
    wireplumber
    # Clipboard
    wl-clipboard
    cliphist
    wl-clip-persist
    # Bluetooth
    bluez
    bluez-utils
    blueman
    # Network
    networkmanager
    network-manager-applet
    # Display / colour
    brightnessctl
    gammastep
    # Qt / GTK theming
    qt6ct
    kvantum
    gtk4
    libadwaita
    # Graphics tools
    grim
    slurp
    imv
    # Files
    nautilus
    file-roller
    # Productivity
    gedit
    gnome-calculator
    gnome-font-viewer
    # Gaming
    gamemode
    lib32-gamemode
    mangohud
    lib32-mangohud
    # Flatpak
    flatpak
    # Wayland compat
    xdg-desktop-portal-hyprland
    xdg-user-dirs
    # Accessibility
    magnus
)

# Add NVIDIA packages if detected
if [[ "$NVIDIA_DETECTED" == "true" ]]; then
    EXTRA_PACKAGES+=(
        nvidia-dkms
        nvidia-utils
        lib32-nvidia-utils
        nvidia-settings
        nvidia-prime
        libva-nvidia-driver
    )
fi

# Build additional-repositories JSON block (include local repo if found)
ADD_REPOS="[]"
if [[ -n "$LOCAL_REPO" ]]; then
    ok "Found local TorrentOS repo: $LOCAL_REPO"
    ADD_REPOS="[{\"name\":\"torrentos\",\"url\":\"file://$LOCAL_REPO\",\"sign_check\":\"Never\",\"sign_option\":\"Never\"}]"
else
    warn "Local TorrentOS package repo not found on live media."
    warn "The installer will try to fetch TorrentOS packages from the internet."
    warn "If that fails, run after reboot: sudo pacman -S torrentos-base torrentos-settings ..."
fi

PKG_JSON="$(printf '%s\n' "${EXTRA_PACKAGES[@]}" | jq -R . | jq -s .)"

# Post-install custom commands (run inside the new system chroot)
CUSTOM_CMDS='[
  "chsh -s /usr/bin/zsh $(getent passwd 1000 | cut -d: -f1 2>/dev/null) 2>/dev/null || true",
  "systemctl enable NetworkManager 2>/dev/null || true",
  "systemctl enable bluetooth 2>/dev/null || true",
  "systemctl enable fstrim.timer 2>/dev/null || true",
  "systemctl enable systemd-resolved 2>/dev/null || true",
  "flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true",
  "ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf 2>/dev/null || true"
]'

# Build graphics driver string
GFX_DRIVER="All open-source (default)"
if [[ "$NVIDIA_DETECTED" == "true" ]]; then
    GFX_DRIVER="Nvidia"
fi

cat > "$CONF_DIR/user_configuration.json" << JSON
{
  "additional-repositories": $ADD_REPOS,
  "archinstall-language": "English",
  "bootloader": "Grub",
  "hostname": "torrentos",
  "kernels": ["linux"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "packages": $PKG_JSON,
  "profile_config": {
    "profile": {
      "custom_settings": {},
      "details": ["Hyprland"],
      "main": "Desktop"
    },
    "gfx_driver": "$GFX_DRIVER"
  },
  "custom-commands": $CUSTOM_CMDS,
  "swap": true,
  "timezone": "UTC"
}
JSON

# в”Ђв”Ђ Launch archinstall в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
step "Launching archinstall with TorrentOS defaults"
log "(You will be prompted to choose your disk, user, and password.)"
echo

archinstall --config "$CONF_DIR/user_configuration.json"

echo
ok "Installation complete!"
printf "\n  ${GRN}вћњ${RST}  Remove the live media and reboot to your new system:\n"
printf "\n     ${BLU}reboot${RST}\n\n"
printf "${CYN}  After first login, the TorrentOS first-boot wizard will guide you\n"
printf "  through personalisation (keyboard, timezone, browser, etc.).${RST}\n\n"
