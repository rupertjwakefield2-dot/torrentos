#!/usr/bin/env bash
# torrentos-update-check — background update checker for TorrentOS
#
# Checks for available pacman + AUR (paru) updates and sends a desktop
# notification if any are found.  Designed to be called by a systemd user
# timer (torrentos-update-check.timer).
#
# Exit codes: 0 = ran OK (updates may or may not exist), 1 = fatal error

set -euo pipefail

NOTIF_APP="TorrentOS Update"
NOTIF_ICON="software-update-available-symbolic"

# ── helpers ───────────────────────────────────────────────────────────────────

notify() {
    local urgency="${1:-normal}" title="$2" body="$3"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send \
            --app-name="$NOTIF_APP" \
            --icon="$NOTIF_ICON" \
            --urgency="$urgency" \
            --action="open=Open Update GUI" \
            "$title" "$body" &
        # Launch updater if user clicks the notification action
        wait $!
        local rv=$?
        if [[ $rv -eq 0 ]]; then
            # libnotify 0.8+ returns 0 and prints action key to stdout
            :
        fi
    fi
}

notify_simple() {
    local title="$1" body="$2"
    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send \
        --app-name="$NOTIF_APP" \
        --icon="$NOTIF_ICON" \
        "$title" "$body" \
        --action="open=Open Update GUI" \
        2>/dev/null &
}

# ── pacman updates via checkupdates (never touches the database) ──────────────

pacman_updates=""
if command -v checkupdates >/dev/null 2>&1; then
    pacman_updates="$(checkupdates 2>/dev/null || true)"
fi

# ── AUR updates via paru / yay ────────────────────────────────────────────────

aur_updates=""
if command -v paru >/dev/null 2>&1; then
    aur_updates="$(paru -Qua 2>/dev/null || true)"
elif command -v yay >/dev/null 2>&1; then
    aur_updates="$(yay -Qua 2>/dev/null || true)"
fi

# ── Count and notify ──────────────────────────────────────────────────────────

pac_count=0
aur_count=0

[[ -n "$pacman_updates" ]] && pac_count="$(echo "$pacman_updates" | grep -c . || true)"
[[ -n "$aur_updates"    ]] && aur_count="$(echo "$aur_updates"    | grep -c . || true)"

total=$(( pac_count + aur_count ))

if [[ $total -eq 0 ]]; then
    # Nothing to do — exit quietly; the last-notified timestamp stays as-is
    exit 0
fi

# Build a readable summary (show up to 5 package names)
summary=""
if [[ $pac_count -gt 0 ]]; then
    top="$(echo "$pacman_updates" | head -5 | awk '{print $1}' | paste -sd ', ')"
    [[ $pac_count -gt 5 ]] && top="${top}, …"
    summary+="${pac_count} package update(s): ${top}"
fi
if [[ $aur_count -gt 0 ]]; then
    [[ -n "$summary" ]] && summary+="\n"
    top="$(echo "$aur_updates" | head -5 | awk '{print $1}' | paste -sd ', ')"
    [[ $aur_count -gt 5 ]] && top="${top}, …"
    summary+="${aur_count} AUR update(s): ${top}"
fi

title="${total} update$([ $total -eq 1 ] && echo '' || echo 's') available"

# Throttle: only notify at most once per 6 hours
stamp_file="${XDG_CACHE_HOME:-$HOME/.cache}/torrentos/last-update-notify"
mkdir -p "$(dirname "$stamp_file")"
now=$(date +%s)
last=0
[[ -f "$stamp_file" ]] && last="$(cat "$stamp_file" 2>/dev/null || echo 0)"
cooldown=$(( 6 * 3600 ))

if (( now - last >= cooldown )); then
    echo "$now" > "$stamp_file"
    # Use printf to expand \n in summary
    notify-send \
        --app-name="$NOTIF_APP" \
        --icon="$NOTIF_ICON" \
        "$title" "$(printf '%b' "$summary")\n\nRun 'torrentos-update-gui' or press Super+U to update." \
        2>/dev/null || true
fi
