#!/usr/bin/env bash
#
# TorrentOS — Dev Mode installer.
# Idempotent. Safe to re-run. Toggled from Settings > Dev Mode, or by hand.
#
set -euo pipefail

log() { printf '\033[1;34m[devmode]\033[0m %s\n' "$*"; }
err() { printf '\033[1;31m[devmode]\033[0m %s\n' "$*" >&2; exit 1; }

[[ $EUID -eq 0 ]] && err "Run as your normal user; sudo is invoked where needed."

if ! command -v paru >/dev/null 2>&1; then
    log "Installing paru (AUR helper)…"
    sudo pacman -S --needed --noconfirm base-devel git
    tmp="$(mktemp -d)"
    git clone https://aur.archlinux.org/paru.git "$tmp/paru"
    (cd "$tmp/paru" && makepkg -si --noconfirm)
    rm -rf "$tmp"
fi

log "Installing language toolchains…"
paru -S --needed --noconfirm \
    rustup go jdk-temurin bun deno mise \
    lazygit lazydocker k9s kubectl helm gh \
    visual-studio-code-bin

log "Setting default toolchain versions via mise…"
mise use --global node@lts || true
mise use --global python@3.12 || true

log "Enabling Docker service…"
sudo systemctl enable --now docker.service
sudo usermod -aG docker "$USER" || true

log "Dev Mode enabled. You may need to log out and back in for docker group to apply."
