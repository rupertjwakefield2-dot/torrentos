# TorrentOS — default git configuration
# Users can override these in ~/.gitconfig.local (see include below)

[core]
    editor        = nvim
    pager         = delta
    autocrlf      = input
    whitespace    = trailing-space,space-before-tab
    precomposeunicode = true

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
    algorithm  = histogram

[delta]
    navigate    = true
    light       = false
    side-by-side = true
    line-numbers = true
    syntax-theme = "Dracula"

[color]
    ui = auto

[color "branch"]
    current  = yellow bold
    local    = green
    remote   = cyan

[color "diff"]
    meta     = yellow
    frag     = magenta bold
    old      = red bold
    new      = green bold

[color "status"]
    added     = green
    changed   = yellow
    untracked = cyan

[alias]
    st   = status -sb
    co   = checkout
    br   = branch
    ci   = commit
    lg   = log --oneline --graph --decorate --all
    lgg  = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
    last = log -1 HEAD --stat
    undo = reset --soft HEAD~1
    unstage = reset HEAD --
    discard = checkout --
    aliases = config --get-regexp alias
    root  = rev-parse --show-toplevel

[url "https://github.com/"]
    insteadOf = gh:

[include]
    path = ~/.gitconfig.local
