# TorrentOS — default Ghostty config
font-family = JetBrainsMono Nerd Font
font-size = 13
theme = TorrentOS

# Translucent macOS-feel terminal
background-opacity = 0.92
background-blur-radius = 20

window-decoration = false
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true

cursor-style = block
cursor-style-blink = false
shell-integration = zsh
copy-on-select = clipboard
confirm-close-surface = false

# Custom theme (matches TorrentOS palette)
[theme = TorrentOS]
background = 0A1628
foreground = F4F7FB
cursor-color = 1E6FFF
selection-background = 1E6FFF
selection-foreground = F4F7FB

palette = 0=#0A1628
palette = 1=#FF6B6B
palette = 2=#5BC0EB
palette = 3=#FFB454
palette = 4=#1E6FFF
palette = 5=#C678DD
palette = 6=#5BC0EB
palette = 7=#F4F7FB
palette = 8=#3B4252
palette = 9=#FF8585
palette = 10=#7AD3F2
palette = 11=#FFCC80
palette = 12=#5C8BFF
palette = 13=#D7A1E5
