# TorrentOS — default Ghostty config
# All settings are flat key=value — Ghostty has no INI sections.
font-family = JetBrainsMono Nerd Font
font-size = 13

# Translucent macOS-feel terminal
background-opacity = 0.92
background-blur-radius = 20

window-decoration = false
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true

cursor-style = block
cursor-style-blink = false
shell-integration = zsh
# Run as login shell so the .zshrc banner fires and /etc/profile is sourced
login-shell = true
copy-on-select = clipboard
confirm-close-surface = false

# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 3

# URL handling — click to open in browser
link-url = true

# Tabs / splits
tab-bar-style = auto
window-new-tab-position = end

# Scrollback
scrollback-limit = 10000

# ── TorrentOS colour palette ──────────────────────────────────────────────────
background             = 0A1628
foreground             = F4F7FB
cursor-color           = 1E6FFF
selection-background   = 1E6FFF
selection-foreground   = F4F7FB

# Normal colours (0-7)
palette = 0=#0A1628
palette = 1=#FF6B6B
palette = 2=#5BC0EB
palette = 3=#FFB454
palette = 4=#1E6FFF
palette = 5=#C678DD
palette = 6=#5BC0EB
palette = 7=#F4F7FB

# Bright colours (8-15)
palette = 8=#3B4252
palette = 9=#FF8585
palette = 10=#7AD3F2
palette = 11=#FFCC80
palette = 12=#5C8BFF
palette = 13=#D7A1E5
palette = 14=#7AD3F2
palette = 15=#FFFFFF
