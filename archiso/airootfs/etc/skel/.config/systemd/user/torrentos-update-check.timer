[Unit]
Description=Check for TorrentOS updates every 6 hours
Documentation=https://torrentos.org/docs

[Timer]
# First check 5 minutes after login (let the network settle)
OnStartupSec=5min
# Then every 6 hours
OnUnitInactiveSec=6h
# Randomise by up to 10 minutes to avoid thundering-herd on shared networks
RandomizedDelaySec=10min
Persistent=true

[Install]
WantedBy=timers.target
