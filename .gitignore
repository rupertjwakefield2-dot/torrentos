# Build artifacts
work/
out/
repo/
*.pkg.tar.*
*.sig

# PKGBUILD-staged sources (regenerated by build-pkgs.sh)
packages/torrentos-base/version
packages/torrentos-base/default-settings.toml
packages/torrentos-base/os-release
packages/torrentos-base/devmode
packages/torrentos-base/settingsd
packages/torrentos-base/firstboot
packages/torrentos-base/torrentos-settingsd.service
packages/torrentos-hyprland-config/hyprland.conf
packages/torrentos-hyprland-config/user.conf
packages/torrentos-hyprland-config/hyprpaper.conf
packages/torrentos-hyprland-config/hyprlock.conf
packages/torrentos-hyprland-config/hypridle.conf
packages/torrentos-hyprland-config/waybar-config.jsonc
packages/torrentos-hyprland-config/waybar-style.css
packages/torrentos-hyprland-config/swaync-config.json
packages/torrentos-hyprland-config/swaync-style.css
packages/torrentos-hyprland-config/rofi-torrentos.rasi
packages/torrentos-hyprland-config/rofi-power-menu.sh
packages/torrentos-hyprland-config/ghostty-config
packages/torrentos-hyprland-config/starship.toml
packages/torrentos-hyprland-config/zshrc
packages/torrentos-base/greetd-config.toml

# makepkg build dirs
packages/*/pkg/
packages/*/src/

# AUR cache (large, cloned from AUR separately)
aur-cache/

# Wallpaper (binary, generated at build time)
packages/torrentos-theme/wallpaper.png

# Sensitive system files (shadow, passwd — generated by releng at build time)
archiso/airootfs/etc/shadow
archiso/airootfs/etc/passwd
archiso/airootfs/etc/gshadow

# Bootloader dirs (generated at build time from releng)
archiso/grub/
archiso/syslinux/
archiso/efiboot/

# Build logs
*.log

# Rendered configs
archiso/pacman.conf.rendered

# Editor noise
.vscode/
.idea/
*.swp
