# Maintainer: TorrentOS <packages@torrentos.org>
pkgname=torrentos-hyprland-config
pkgver=0.1.0
pkgrel=1
pkgdesc="TorrentOS default Hyprland, Waybar, swaync, ghostty, and shell configs"
arch=('any')
url="https://torrentos.org"
license=('GPL3')
depends=(
    'hyprland'
    'waybar'
    'swaync'
    'ghostty'
    'rofi-wayland'
    'starship'
)
source=(
    'hyprland.conf'
    'user.conf'
    'hyprpaper.conf'
    'hyprlock.conf'
    'hypridle.conf'
    'waybar-config.jsonc'
    'waybar-style.css'
    'swaync-config.json'
    'ghostty-config'
    'starship.toml'
    'zshrc'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    local skel="$pkgdir/etc/skel/.config"
    install -Dm644 "$srcdir/hyprland.conf"        "$skel/hypr/hyprland.conf"
    install -Dm644 "$srcdir/user.conf"            "$skel/hypr/user.conf"
    install -Dm644 "$srcdir/hyprpaper.conf"       "$skel/hypr/hyprpaper.conf"
    install -Dm644 "$srcdir/hyprlock.conf"        "$skel/hypr/hyprlock.conf"
    install -Dm644 "$srcdir/hypridle.conf"        "$skel/hypr/hypridle.conf"
    install -Dm644 "$srcdir/waybar-config.jsonc"  "$skel/waybar/config.jsonc"
    install -Dm644 "$srcdir/waybar-style.css"     "$skel/waybar/style.css"
    install -Dm644 "$srcdir/swaync-config.json"   "$skel/swaync/config.json"
    install -Dm644 "$srcdir/ghostty-config"       "$skel/ghostty/config"
    install -Dm644 "$srcdir/starship.toml"        "$skel/starship.toml"
    install -Dm644 "$srcdir/zshrc"                "$pkgdir/etc/skel/.zshrc"
}
