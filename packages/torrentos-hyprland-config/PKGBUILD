# Maintainer: TorrentOS <packages@torrentos.org>
pkgname=torrentos-hyprland-config
pkgver=0.5.0
pkgrel=1
pkgdesc="TorrentOS default Hyprland, Waybar, swaync, rofi, ghostty, and shell configs"
arch=('any')
url="https://torrentos.org"
license=('GPL3')
depends=(
    'hyprland'
    'waybar'
    'swaync'
    'ghostty'
    'rofi-wayland'
    'starship'
)
source=(
    'hyprland.conf'
    'user.conf'
    'hyprpaper.conf'
    'hyprlock.conf'
    'hypridle.conf'
    'waybar-config.jsonc'
    'waybar-style.css'
    'swaync-config.json'
    'swaync-style.css'
    'rofi-torrentos.rasi'
    'rofi-power-menu.sh'
    'ghostty-config'
    'starship.toml'
    'zshrc'
    'nwg-dock-style.css'
    'gtk3-settings.ini'
    'gtk4-settings.ini'
    'fonts.conf'
    'mimeapps.list'
    'user-dirs.dirs'
    'qt6ct.conf'
    'libinput-gestures.conf'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    local skel="$pkgdir/etc/skel/.config"

    install -Dm644 "$srcdir/hyprland.conf"        "$skel/hypr/hyprland.conf"
    install -Dm644 "$srcdir/user.conf"            "$skel/hypr/user.conf"
    install -Dm644 "$srcdir/hyprpaper.conf"       "$skel/hypr/hyprpaper.conf"
    install -Dm644 "$srcdir/hyprlock.conf"        "$skel/hypr/hyprlock.conf"
    install -Dm644 "$srcdir/hypridle.conf"        "$skel/hypr/hypridle.conf"

    install -Dm644 "$srcdir/waybar-config.jsonc"  "$skel/waybar/config.jsonc"
    install -Dm644 "$srcdir/waybar-style.css"     "$skel/waybar/style.css"

    install -Dm644 "$srcdir/swaync-config.json"   "$skel/swaync/config.json"
    install -Dm644 "$srcdir/swaync-style.css"     "$skel/swaync/style.css"

    install -Dm644 "$srcdir/rofi-torrentos.rasi"  "$skel/rofi/torrentos.rasi"
    install -Dm755 "$srcdir/rofi-power-menu.sh"   "$skel/rofi/power-menu.sh"

    install -Dm644 "$srcdir/ghostty-config"       "$skel/ghostty/config"
    install -Dm644 "$srcdir/starship.toml"        "$skel/starship.toml"

    install -Dm644 "$srcdir/nwg-dock-style.css"   "$skel/nwg-dock-hyprland/style.css"

    install -Dm644 "$srcdir/gtk3-settings.ini"    "$skel/gtk-3.0/settings.ini"
    install -Dm644 "$srcdir/gtk4-settings.ini"    "$skel/gtk-4.0/settings.ini"

    install -Dm644 "$srcdir/fonts.conf"           "$skel/fontconfig/fonts.conf"
    install -Dm644 "$srcdir/mimeapps.list"        "$skel/mimeapps.list"
    install -Dm644 "$srcdir/user-dirs.dirs"       "$skel/user-dirs.dirs"
    install -Dm644 "$srcdir/qt6ct.conf"                "$skel/qt6ct/qt6ct.conf"
    install -Dm644 "$srcdir/libinput-gestures.conf"    "$skel/libinput-gestures.conf"

    install -Dm644 "$srcdir/zshrc"                     "$pkgdir/etc/skel/.zshrc"
}
