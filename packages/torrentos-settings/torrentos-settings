#!/usr/bin/env python3
"""TorrentOS Settings — launcher."""
import os
import sys

# Find the bundled python source — installed by the package to a fixed path.
_PKG_ROOT = "/usr/share/torrentos-settings"
if _PKG_ROOT not in sys.path:
    sys.path.insert(0, _PKG_ROOT)

from torrentos_settings.app import main  # noqa: E402

raise SystemExit(main())
