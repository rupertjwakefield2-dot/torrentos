# ── Window ────────────────────────────────────────────────────────────────────

class FirstBootWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.set_title("Welcome to TorrentOS")
        self.set_default_size(680, 540)
        self.set_resizable(False)

        self._kb_page = KeyboardPage()
        self._pages = [WelcomePage(), self._kb_page, WiFiPage(), ShortcutsPage(), FinishPage()]
        self._idx = 0

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.set_content(outer)

        header = Adw.HeaderBar()
        header.set_show_end_title_buttons(False)
        outer.append(header)

        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
        self._stack.set_vexpand(True)
        for i, p in enumerate(self._pages):
            self._stack.add_named(p, str(i))
        outer.append(self._stack)

        # Progress dots
        dots_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        dots_box.set_halign(Gtk.Align.CENTER)
        dots_box.set_margin_bottom(6)
        self._dots = []
        for i in range(len(self._pages)):
            dot = Gtk.Label(label="●")
            dot.add_css_class("dim-label")
            dots_box.append(dot)
            self._dots.append(dot)
        outer.append(dots_box)

        nav = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        nav.set_margin_start(20); nav.set_margin_end(20); nav.set_margin_bottom(14)

        self._back_btn = Gtk.Button(label="Back")
        self._back_btn.connect("clicked", lambda _: self._go(-1))
        nav.append(self._back_btn)

        skip_btn = Gtk.Button(label="Skip WiFi")
        skip_btn.add_css_class("flat")
        skip_btn.connect("clicked", lambda _: self._go(1))
        self._skip_btn = skip_btn
        nav.append(skip_btn)

        spacer = Gtk.Label(); spacer.set_hexpand(True)
        nav.append(spacer)

        self._next_btn = Gtk.Button(label="Next")
        self._next_btn.add_css_class("suggested-action")
        self._next_btn.connect("clicked", lambda _: self._go(1))
        nav.append(self._next_btn)

        outer.append(nav)
        self._update_ui()

    def _go(self, direction):
        n = len(self._pages)
        new = self._idx + direction
        if new < 0:
            return
        if new >= n:
            self._finish()
            return
        self._idx = new
        self._update_ui()

    def _update_ui(self):
        i = self._idx
        n = len(self._pages)
        self._stack.set_visible_child_name(str(i))
        self._back_btn.set_sensitive(i > 0)
        self._next_btn.set_label("Finish" if i == n - 1 else "Next")
        # Show skip only on WiFi page (index 2)
        self._skip_btn.set_visible(i == 2)
        for j, dot in enumerate(self._dots):
            dot.remove_css_class("dim-label")
            dot.remove_css_class("accent")
            dot.add_css_class("accent" if j == i else "dim-label")

    def _finish(self):
        MARKER.parent.mkdir(parents=True, exist_ok=True)
        MARKER.touch()
        self.get_application().quit()


class FirstBootApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.torrentos.FirstBoot",
                         flags=Gio.ApplicationFlags.FLAGS_NONE)
        self.connect("activate", self._on_activate)

    def _on_activate(self, app):
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
        FirstBootWindow(app).present()


def main():
    if MARKER.exists():
        sys.exit(0)
    sys.exit(FirstBootApp().run(sys.argv))


if __name__ == "__main__":
    main()
