def run(cmd, **kw):
    return subprocess.run(cmd, capture_output=True, text=True, **kw)

def write_user_conf(key, value, section="input"):
    USR_CONF.parent.mkdir(parents=True, exist_ok=True)
    content = USR_CONF.read_text() if USR_CONF.exists() else ""
    pattern = rf'{re.escape(key)}\s*=\s*\S+'
    replacement = f"{key} = {value}"
    if re.search(pattern, content):
        content = re.sub(pattern, replacement, content)
    else:
        block = f"\n{section} {{\n    {replacement}\n}}\n"
        content += block
    USR_CONF.write_text(content)

