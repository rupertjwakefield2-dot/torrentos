class KeyboardPage(Gtk.Box):
    def __init__(self):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.set_margin_start(32); self.set_margin_end(32)
        self.set_margin_top(24);   self.set_margin_bottom(24)
        self._selected = "gb"

        self.append(make_page_header(
            "Keyboard Layout",
            "Choose the layout that matches your physical keyboard."
        ))

        # Search
        self._search = Gtk.SearchEntry()
        self._search.set_placeholder_text("Search layouts…")
        self._search.connect("search-changed", self._on_search)
        self.append(self._search)

        # List box
        self._listbox = Gtk.ListBox()
        self._listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self._listbox.add_css_class("boxed-list")
        self._listbox.connect("row-selected", self._on_row_selected)
        self._all_rows = []
        self._populate_list(KEYBOARD_LAYOUTS)
        self.append(scrolled(self._listbox, 240))

        # Test field
        test_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        test_lbl = Gtk.Label(label="Test your layout")
        test_lbl.set_halign(Gtk.Align.START)
        test_lbl.add_css_class("page-sub")
        self._entry = Gtk.Entry()
        self._entry.set_placeholder_text('Type here — try @ " # £ etc.')
        self._entry.set_hexpand(True)
        test_box.append(test_lbl)
        test_box.append(self._entry)
        self.append(test_box)

        self._status = Gtk.Label(label="")
        self._status.set_halign(Gtk.Align.START)
        self.append(self._status)

    def _populate_list(self, layouts):
        while row := self._listbox.get_row_at_index(0):
            self._listbox.remove(row)
        self._all_rows = []
        first = None
        for code, flag, name, native in layouts:
            row = Adw.ActionRow()
            row.set_title(f"{flag}  {name}")
            row.set_subtitle(native)
            row._kb_code = code
            self._listbox.append(row)
            self._all_rows.append(row)
            if first is None:
                first = row
        if first:
            self._listbox.select_row(first)

    def _on_search(self, entry):
        q = entry.get_text().lower()
        filtered = [(c, f, n, nat) for c, f, n, nat in KEYBOARD_LAYOUTS
                    if q in n.lower() or q in c.lower() or q in nat.lower()]
        self._populate_list(filtered if q else KEYBOARD_LAYOUTS)

    def _on_row_selected(self, lb, row):
        if row is None:
            return
        self._selected = row._kb_code
        run(["localectl", "set-keymap", self._selected])
        write_user_conf("kb_layout", self._selected, "input")
        self._status.set_text(f"✓  Layout set to {self._selected}")
        self._status.remove_css_class("status-err")
        self._status.add_css_class("status-ok")

    def get_selected(self):
        return self._selected


class TimezonePage(Gtk.Box):
    def __init__(self):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.set_margin_start(32); self.set_margin_end(32)
        self.set_margin_top(24);   self.set_margin_bottom(24)
        self._selected_tz = "Europe/London"

        self.append(make_page_header(
            "Timezone",
            "Select your timezone so the clock shows the right time."
        ))

        self._search = Gtk.SearchEntry()
        self._search.set_placeholder_text("Search cities…")
        self._search.connect("search-changed", self._on_search)
        self.append(self._search)

        self._listbox = Gtk.ListBox()
        self._listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self._listbox.add_css_class("boxed-list")
        self._listbox.connect("row-selected", self._on_selected)
        self._populate(TIMEZONES)
        self.append(scrolled(self._listbox, 300))

        self._status = Gtk.Label(label="")
        self._status.set_halign(Gtk.Align.START)
        self.append(self._status)

    def _populate(self, zones):
        while row := self._listbox.get_row_at_index(0):
            self._listbox.remove(row)
        first = None
        for tz, flag, city, offset in zones:
            row = Adw.ActionRow()
            row.set_title(f"{flag}  {city}")
            row.set_subtitle(f"{tz}  ·  {offset}")
            row._tz = tz
            self._listbox.append(row)
            if first is None:
                first = row
        if first:
            self._listbox.select_row(first)

    def _on_search(self, entry):
        q = entry.get_text().lower()
        filtered = [(tz, f, c, o) for tz, f, c, o in TIMEZONES
                    if q in c.lower() or q in tz.lower() or q in o.lower()]
        self._populate(filtered if q else TIMEZONES)

    def _on_selected(self, lb, row):
        if row is None:
            return
        self._selected_tz = row._tz
        try:
            run(["timedatectl", "set-timezone", self._selected_tz])
        except Exception:
            pass
        self._status.set_text(f"✓  Timezone set to {self._selected_tz}")
        self._status.remove_css_class("status-err")
        self._status.add_css_class("status-ok")


