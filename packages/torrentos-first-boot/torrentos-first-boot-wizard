        pw_row.append(self._pw)
        pw_row.append(self._connect_btn)
        pw_card.append(pw_row)

        self._conn_status = Gtk.Label(label="")
        self._conn_status.set_halign(Gtk.Align.START)
        self._conn_status.set_margin_start(12)
        self._conn_status.set_margin_bottom(8)
        pw_card.append(self._conn_status)
        self.append(pw_card)

        threading.Thread(target=self._scan, daemon=True).start()

    def _signal_icon(self, pct):
        p = int(pct) if pct.isdigit() else 0
        if p >= 75: return "network-wireless-signal-excellent-symbolic"
        if p >= 50: return "network-wireless-signal-good-symbolic"
        if p >= 25: return "network-wireless-signal-ok-symbolic"
        return "network-wireless-signal-weak-symbolic"

    def _scan(self):
        GLib.idle_add(self._scan_status.set_text, "Scanning…")
        run(["nmcli", "device", "wifi", "rescan"])
        result = run(["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY,IN-USE", "device", "wifi", "list"])
        networks, seen = [], set()
        raw = []
        for line in result.stdout.splitlines():
            parts = line.split(":")
            ssid = parts[0].strip() if parts else ""
            if not ssid or ssid in seen:
                continue
            seen.add(ssid)
            sig  = parts[1] if len(parts) > 1 else "0"
            sec  = parts[2] if len(parts) > 2 else ""
            inuse = parts[3].strip() == "*" if len(parts) > 3 else False
            networks.append((ssid, sig, sec, inuse))
            raw.append(ssid)
        self._networks_raw = raw
        GLib.idle_add(self._populate, networks)

    def _populate(self, networks):
        while row := self._listbox.get_row_at_index(0):
            self._listbox.remove(row)
        if not networks:
            self._scan_status.set_text("No networks found")
            return
        self._scan_status.set_text(f"Found {len(networks)} network(s)")
        for ssid, sig, sec, inuse in networks:
            row = Adw.ActionRow()
            row.set_title(ssid)
            status_parts = []
            if inuse:
                status_parts.append("Connected")
            if sec and sec != "--":
                status_parts.append("Secured")
            else:
                status_parts.append("Open")
            status_parts.append(f"{sig}%")
            row.set_subtitle("  ·  ".join(status_parts))
            row._ssid = ssid
            icon = Gtk.Image.new_from_icon_name(self._signal_icon(sig))
            icon.set_pixel_size(20)
            row.add_prefix(icon)
            if inuse:
                check = Gtk.Image.new_from_icon_name("emblem-ok-symbolic")
                check.add_css_class("success")
                row.add_suffix(check)
            if sec and sec != "--":
                lock = Gtk.Image.new_from_icon_name("channel-secure-symbolic")
                row.add_suffix(lock)
            self._listbox.append(row)

    def _on_connect(self, _):
        row = self._listbox.get_selected_row()
        if row is None:
            self._conn_status.set_text("Please select a network first")
            return
        ssid = row._ssid
        pw   = self._pw.get_text()
        self._connect_btn.set_sensitive(False)
        self._conn_status.set_text("Connecting…")
        threading.Thread(target=self._do_connect, args=(ssid, pw), daemon=True).start()

    def _do_connect(self, ssid, pw):
        if pw:
            r = run(["nmcli", "device", "wifi", "connect", ssid, "password", pw])
        else:
            r = run(["nmcli", "device", "wifi", "connect", ssid])
        ok  = r.returncode == 0
        msg = f"✓  Connected to {ssid}" if ok else f"✗  {r.stderr.strip()[:70]}"
        GLib.idle_add(self._set_status, msg, ok)

    def _set_status(self, msg, ok):
        self._conn_status.set_text(msg)
        self._conn_status.remove_css_class("status-ok")
        self._conn_status.remove_css_class("status-err")
        self._conn_status.add_css_class("status-ok" if ok else "status-err")
        self._connect_btn.set_sensitive(True)


