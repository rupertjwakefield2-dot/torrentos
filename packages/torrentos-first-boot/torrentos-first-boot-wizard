class KeyboardPage(Gtk.Box):
    def __init__(self):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        self.set_valign(Gtk.Align.CENTER)
        self.set_halign(Gtk.Align.CENTER)
        self.set_margin_top(32); self.set_margin_bottom(32)
        self.set_margin_start(48); self.set_margin_end(48)
        self._selected = "us"

        heading = Gtk.Label(label="Keyboard Layout")
        heading.add_css_class("section-title")
        heading.set_halign(Gtk.Align.START)
        self.append(heading)

        sub = Gtk.Label(label="Choose the layout that matches your physical keyboard.")
        sub.add_css_class("dim-label")
        sub.set_halign(Gtk.Align.START)
        self.append(sub)

        # Dropdown
        self._model = Gtk.StringList()
        for code, label in KEYBOARD_LAYOUTS:
            self._model.append(label)

        self._dropdown = Gtk.DropDown(model=self._model)
        self._dropdown.set_selected(0)
        self._dropdown.connect("notify::selected", self._on_changed)
        self.append(self._dropdown)

        # Test label
        self._test_entry = Gtk.Entry()
        self._test_entry.set_placeholder_text('Type here to test — try " @ # etc.')
        self._test_entry.set_hexpand(True)
        self.append(self._test_entry)

        self._status = Gtk.Label(label="")
        self._status.set_halign(Gtk.Align.START)
        self.append(self._status)

    def _on_changed(self, dd, _):
        idx = dd.get_selected()
        self._selected = KEYBOARD_LAYOUTS[idx][0]
        self._apply_layout()

    def _apply_layout(self):
        code = self._selected
        # Apply to running session
        run(["localectl", "set-keymap", code])
        # Also write to hyprland user config so it persists after reboot
        hypr_user = Path.home() / ".config" / "hypr" / "user.conf"
        hypr_user.parent.mkdir(parents=True, exist_ok=True)
        content = hypr_user.read_text() if hypr_user.exists() else ""
        import re
        kb_line = f"input {{\n    kb_layout = {code}\n}}\n"
        if "kb_layout" in content:
            content = re.sub(r'kb_layout\s*=\s*\S+', f'kb_layout = {code}', content)
        else:
            content += "\n" + kb_line
        hypr_user.write_text(content)
        self._status.set_text(f"✓ Layout set to {code}")
        self._status.add_css_class("status-ok")

    def get_selected(self):
        return self._selected


class WiFiPage(Gtk.Box):
    def __init__(self):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        self.set_valign(Gtk.Align.CENTER)
        self.set_halign(Gtk.Align.CENTER)
        self.set_margin_top(32); self.set_margin_bottom(32)
        self.set_margin_start(48); self.set_margin_end(48)

        heading = Gtk.Label(label="Connect to WiFi")
        heading.add_css_class("section-title")
        heading.set_halign(Gtk.Align.START)
        self.append(heading)

        self._status = Gtk.Label(label="Scanning…")
        self._status.set_halign(Gtk.Align.START)
        self._status.add_css_class("dim-label")
        self.append(self._status)

        # Network list
        self._list_store = Gtk.StringList()
        self._list_view_factory = Gtk.SignalListItemFactory()
        self._list_view_factory.connect("setup", self._setup_item)
        self._list_view_factory.connect("bind", self._bind_item)

        self._selection = Gtk.SingleSelection(model=self._list_store)
        self._list_box = Gtk.ListView(model=self._selection, factory=self._list_view_factory)
        self._list_box.set_size_request(400, 160)

        scroll = Gtk.ScrolledWindow()
        scroll.set_child(self._list_box)
        scroll.set_vexpand(False)
        self.append(scroll)

        # Password
        pw_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._pw = Gtk.PasswordEntry()
        self._pw.set_hexpand(True)
        self._pw.set_placeholder_text("WiFi Password")
        self._pw.set_show_peek_icon(True)
        pw_row.append(self._pw)

        self._connect_btn = Gtk.Button(label="Connect")
        self._connect_btn.add_css_class("suggested-action")
        self._connect_btn.connect("clicked", self._on_connect)
        pw_row.append(self._connect_btn)
        self.append(pw_row)

        self._conn_status = Gtk.Label(label="")
        self._conn_status.set_halign(Gtk.Align.START)
        self.append(self._conn_status)

        # Scan in background
        threading.Thread(target=self._scan, daemon=True).start()

    def _setup_item(self, factory, item):
        item.set_child(Gtk.Label(xalign=0))

    def _bind_item(self, factory, item):
        item.get_child().set_label(item.get_item().get_string())

    def _scan(self):
        run(["nmcli", "device", "wifi", "rescan"])
        result = run(["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY", "device", "wifi", "list"])
        networks = []
        seen = set()
        for line in result.stdout.splitlines():
            parts = line.split(":")
            if parts and parts[0] and parts[0] not in seen:
                seen.add(parts[0])
                sig = parts[1] if len(parts) > 1 else "?"
                sec = parts[2] if len(parts) > 2 else ""
                lock = "🔒 " if sec and sec != "--" else "   "
                networks.append(f"{lock}{parts[0]}  ({sig}%)")
        self._networks_raw = [line.split(":")[0] for line in result.stdout.splitlines()
                               if line.split(":")[0]]
        GLib.idle_add(self._populate, networks)

    def _populate(self, networks):
        while self._list_store.get_n_items():
            self._list_store.remove(0)
        if networks:
            for n in networks:
                self._list_store.append(n)
            self._status.set_text(f"Found {len(networks)} network(s) — select one below")
        else:
            self._status.set_text("No networks found — check your WiFi adapter")

    def _on_connect(self, _):
        idx = self._selection.get_selected()
        if idx == Gtk.INVALID_LIST_POSITION or idx >= len(getattr(self, "_networks_raw", [])):
            self._conn_status.set_text("Please select a network first")
            return
        ssid = self._networks_raw[idx]
        pw = self._pw.get_text()
        self._connect_btn.set_sensitive(False)
        self._conn_status.set_text("Connecting…")
        threading.Thread(target=self._do_connect, args=(ssid, pw), daemon=True).start()

    def _do_connect(self, ssid, pw):
        if pw:
            r = run(["nmcli", "device", "wifi", "connect", ssid, "password", pw])
        else:
            r = run(["nmcli", "device", "wifi", "connect", ssid])
        ok = r.returncode == 0
        msg = f"✓ Connected to {ssid}" if ok else f"✗ Failed: {r.stderr.strip()[:60]}"
        GLib.idle_add(self._set_conn_status, msg, ok)

    def _set_conn_status(self, msg, ok):
        self._conn_status.set_text(msg)
        self._conn_status.remove_css_class("status-ok")
        self._conn_status.remove_css_class("status-err")
        self._conn_status.add_css_class("status-ok" if ok else "status-err")
        self._connect_btn.set_sensitive(True)


