PAGE_TITLES = ["Welcome", "Keyboard", "Timezone", "Appearance", "WiFi", "Shortcuts", "Finish"]

class FirstBootWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.set_title("TorrentOS Setup")
        self.set_default_size(720, 600)
        self.set_resizable(True)

        self._kb_page  = KeyboardPage()
        self._tz_page  = TimezonePage()
        self._app_page = AppearancePage()
        self._pages = [
            WelcomePage(),
            self._kb_page,
            self._tz_page,
            self._app_page,
            WiFiPage(),
            ShortcutsPage(),
            FinishPage(),
        ]
        self._idx = 0
        self._n   = len(self._pages)

        # Root layout
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.set_content(root)

        # Header bar
        self._header = Adw.HeaderBar()
        self._header.set_show_end_title_buttons(False)
        self._page_label = Gtk.Label()
        self._page_label.add_css_class("heading")
        self._header.set_title_widget(self._page_label)
        root.append(self._header)

        # Progress bar
        self._progress = Gtk.ProgressBar()
        self._progress.set_fraction(0)
        root.append(self._progress)

        # Stack
        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
        self._stack.set_transition_duration(280)
        self._stack.set_vexpand(True)
        for i, p in enumerate(self._pages):
            sw = Gtk.ScrolledWindow()
            sw.set_child(p)
            sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
            self._stack.add_named(sw, str(i))
        root.append(self._stack)

        # Nav bar
        nav = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        nav.add_css_class("nav-bar")

        self._back_btn = Gtk.Button(label="Back")
        self._back_btn.add_css_class("flat")
        self._back_btn.connect("clicked", lambda _: self._go(-1))
        nav.append(self._back_btn)

        self._skip_btn = Gtk.Button(label="Skip")
        self._skip_btn.add_css_class("flat")
        self._skip_btn.connect("clicked", lambda _: self._go(1))
        nav.append(self._skip_btn)

        spacer = Gtk.Label()
        spacer.set_hexpand(True)
        nav.append(spacer)

        # Step counter
        self._step_label = Gtk.Label()
        self._step_label.add_css_class("dim-label")
        nav.append(self._step_label)

        self._next_btn = Gtk.Button()
        self._next_btn.add_css_class("suggested-action")
        self._next_btn.add_css_class("pill")
        self._next_btn.connect("clicked", lambda _: self._go(1))
        nav.append(self._next_btn)

        root.append(nav)
        self._update_ui()

    def _go(self, direction):
        new = self._idx + direction
        if new < 0:
            return
        if new >= self._n:
            self._finish()
            return
        self._idx = new
        self._stack.set_transition_type(
            Gtk.StackTransitionType.SLIDE_LEFT if direction > 0
            else Gtk.StackTransitionType.SLIDE_RIGHT
        )
        self._update_ui()

    def _update_ui(self):
        i, n = self._idx, self._n
        self._stack.set_visible_child_name(str(i))
        self._page_label.set_label(PAGE_TITLES[i])
        self._progress.set_fraction((i) / (n - 1))
        self._back_btn.set_sensitive(i > 0)
        self._next_btn.set_label("Finish" if i == n - 1 else "Continue →")
        # Skip shown only on WiFi page
        self._skip_btn.set_visible(i == 4)
        self._step_label.set_label(f"{i + 1} of {n}")

    def _finish(self):
        MARKER.parent.mkdir(parents=True, exist_ok=True)
        MARKER.touch()
        self.get_application().quit()


class FirstBootApp(Adw.Application):
    def __init__(self):
        super().__init__(
            application_id="org.torrentos.FirstBoot",
            flags=Gio.ApplicationFlags.FLAGS_NONE,
        )
        self.connect("activate", self._on_activate)

    def _on_activate(self, app):
        mgr = Adw.StyleManager.get_default()
        mgr.set_color_scheme(Adw.ColorScheme.FORCE_DARK)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )
        win = FirstBootWindow(app)
        win.present()


def main():
    if MARKER.exists():
        sys.exit(0)
    sys.exit(FirstBootApp().run(sys.argv))


if __name__ == "__main__":
    main()
