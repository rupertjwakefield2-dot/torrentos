            mgr.set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        else:
            mgr.set_color_scheme(Adw.ColorScheme.FORCE_LIGHT)

    def _on_swatch(self, btn, colour, widget):
        self._accent = colour
        if self._active_swatch:
            self._active_swatch.remove_css_class("active")
        widget.add_css_class("active")
        self._active_swatch = widget


