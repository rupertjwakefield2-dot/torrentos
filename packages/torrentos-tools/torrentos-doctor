#!/usr/bin/env bash
# torrentos-doctor — TorrentOS system health check
# Runs a series of quick diagnostic checks and reports pass/fail with hints.
# Usage: torrentos-doctor [--quiet] [--fix]

set -euo pipefail

QUIET=0
FIX=0
for arg in "$@"; do
    case "$arg" in
        --quiet) QUIET=1 ;;
        --fix)   FIX=1   ;;
    esac
done

B='\033[38;2;30;111;255m'
G='\033[38;2;91;235;161m'
Y='\033[38;2;255;180;84m'
R='\033[38;2;255;107;107m'
W='\033[1;37m'
D='\033[2;37m'
N='\033[0m'

PASS=0
WARN=0
FAIL=0

# Track failed check names for --fix suggestions
FAILED_CHECKS=()

header() {
    [[ $QUIET -eq 1 ]] && return
    echo
    printf "${B}  TorrentOS Doctor${N}\n"
    printf "${D}  ─────────────────────────────────────────────────${N}\n"
    echo
}

ok()   { PASS=$(( PASS + 1 )); [[ $QUIET -eq 0 ]] && printf "${G}  ✔${N}  %s\n" "$1"; }
warn() { WARN=$(( WARN + 1 )); printf "${Y}  ⚠${N}  %s\n" "$1"; }
fail() { FAIL=$(( FAIL + 1 )); FAILED_CHECKS+=("$1"); printf "${R}  ✘${N}  %s\n" "$1"; }
hint() { [[ $QUIET -eq 0 ]] && printf "${D}     ↳ %s${N}\n" "$1"; }

# ── checks ────────────────────────────────────────────────────────────────────

check_cmd() {
    local cmd="$1" label="${2:-$1}" fix="${3:-}"
    if command -v "$cmd" >/dev/null 2>&1; then
        ok "$label is installed"
    else
        fail "$label not found"
        [[ -n "$fix" ]] && hint "$fix"
    fi
}

check_service_active() {
    local unit="$1" label="${2:-$1}"
    if systemctl is-active --quiet "$unit" 2>/dev/null; then
        ok "$label is running"
    else
        warn "$label is not active"
        hint "sudo systemctl start $unit"
    fi
}

check_user_service() {
    local unit="$1" label="${2:-$1}"
    if systemctl --user is-active --quiet "$unit" 2>/dev/null; then
        ok "$label (user) is running"
    else
        warn "$label (user) is not active"
        hint "systemctl --user start $unit"
    fi
}

check_file() {
    local path="$1" label="$2" fix="${3:-}"
    if [[ -e "$path" ]]; then
        ok "$label exists"
    else
        fail "$label missing: $path"
        [[ -n "$fix" ]] && hint "$fix"
    fi
}

check_writable() {
    local path="$1" label="$2"
    if [[ -w "$path" ]]; then
        ok "$label is writable"
    else
        fail "$label is not writable: $path"
        hint "Check permissions with: ls -la $(dirname "$path")"
    fi
}

check_internet() {
    if ping -c 1 -W 3 1.1.1.1 >/dev/null 2>&1; then
        ok "Internet reachable"
    else
        warn "No internet connection"
        hint "Use nmtui or nm-connection-editor to connect"
    fi
}

check_disk_space() {
    local threshold=10  # warn if < 10 GB free on /
    local free_kb
    free_kb=$(df --output=avail / | tail -1)
    local free_gb=$(( free_kb / 1024 / 1024 ))
    if (( free_gb >= threshold )); then
        ok "Disk space OK (${free_gb} GB free on /)"
    else
        warn "Low disk space: ${free_gb} GB free on /"
        hint "sudo pacman -Sc  # clean package cache"
    fi
}

check_gpu() {
    if command -v glxinfo >/dev/null 2>&1; then
        local renderer
        renderer="$(glxinfo 2>/dev/null | grep 'OpenGL renderer' | cut -d: -f2 | xargs || echo '?')"
        ok "GPU: ${renderer}"
    elif command -v vulkaninfo >/dev/null 2>&1; then
        ok "Vulkan GPU info available"
    else
        warn "glxinfo / vulkaninfo not found — cannot confirm GPU"
        hint "sudo pacman -S mesa-utils"
    fi
}

check_nvidia() {
    # Only run if an NVIDIA GPU is present
    if ! lspci 2>/dev/null | grep -qi nvidia; then
        return
    fi
    printf "${W}  NVIDIA${N}\n"
    # Check kernel module is loaded
    if lsmod 2>/dev/null | grep -q "^nvidia "; then
        ok "nvidia kernel module loaded"
    else
        fail "nvidia module not loaded — Hyprland will not start"
        hint "sudo modprobe nvidia && sudo modprobe nvidia_drm modeset=1"
        if [[ $FIX -eq 1 ]]; then
            printf "${Y}  Attempting to load NVIDIA modules…${N}\n"
            sudo modprobe nvidia nvidia_modeset nvidia_uvm nvidia_drm 2>/dev/null && \
                printf "${G}  ✔  Modules loaded.${N}\n" || \
                printf "${R}  ✘  Failed — is nvidia-dkms installed?${N}\n"
        fi
    fi
    # Check DRM modeset is enabled (required for Wayland)
    local modeset
    modeset="$(cat /sys/module/nvidia_drm/parameters/modeset 2>/dev/null || echo '?')"
    if [[ "$modeset" == "Y" ]]; then
        ok "nvidia_drm modeset=1 (Wayland KMS active)"
    else
        warn "nvidia_drm modeset not enabled (current: ${modeset})"
        hint "Add 'options nvidia_drm modeset=1' to /etc/modprobe.d/nvidia.conf"
    fi
    # Check WLR_NO_HARDWARE_CURSORS is set (prevents invisible cursor)
    if [[ "${WLR_NO_HARDWARE_CURSORS:-}" == "1" ]]; then
        ok "WLR_NO_HARDWARE_CURSORS=1 set (cursor fix active)"
    else
        warn "WLR_NO_HARDWARE_CURSORS not set — cursor may be invisible"
        hint "Add WLR_NO_HARDWARE_CURSORS=1 to /etc/environment.d/91-torrentos-nvidia.conf"
    fi
    echo
}

check_audio() {
    if command -v pactl >/dev/null 2>&1 && pactl info >/dev/null 2>&1; then
        ok "PipeWire/PulseAudio audio server running"
    else
        warn "Audio server not responding"
        hint "systemctl --user restart pipewire pipewire-pulse"
    fi
}

check_hyprland_socket() {
    local rt="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    if ls "${rt}/hypr/"*"/hyprland.lock" >/dev/null 2>&1; then
        ok "Hyprland socket present"
    else
        warn "Hyprland socket not found"
        hint "Are you running inside Hyprland?"
    fi
}

check_settings_file() {
    local path="$HOME/.config/torrentos/settings.toml"
    if [[ -f "$path" ]]; then
        ok "User settings file exists"
        # Basic TOML parse check
        if python3 -c "
import sys
try:
    import tomllib
except ImportError:
    import tomli as tomllib
with open('$path','rb') as f: tomllib.load(f)
" 2>/dev/null; then
            ok "User settings TOML is valid"
        else
            fail "User settings TOML is malformed"
            hint "Edit or delete: $path"
        fi
    else
        ok "No user overrides (using defaults)"
    fi
}

check_pacman_lock() {
    if [[ -f /var/lib/pacman/db.lck ]]; then
        warn "pacman DB lock exists — another pacman may be running"
        hint "If no pacman is running: sudo rm /var/lib/pacman/db.lck"
    else
        ok "pacman DB not locked"
    fi
}

check_failed_units() {
    local failed
    failed="$(systemctl --failed --no-legend 2>/dev/null | awk '{print $1}' | paste -sd ' ' || true)"
    if [[ -z "$failed" ]]; then
        ok "No failed system units"
    else
        warn "Failed units: $failed"
        hint "systemctl status $failed"
    fi
}

check_flatpak() {
    if command -v flatpak >/dev/null 2>&1; then
        ok "flatpak is installed"
        if flatpak remotes 2>/dev/null | grep -q flathub; then
            ok "Flathub remote is configured"
        else
            warn "Flathub remote not found"
            hint "flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo"
        fi
    else
        warn "flatpak not installed"
        hint "sudo pacman -S flatpak"
    fi
}

check_aur_helper() {
    if command -v paru >/dev/null 2>&1; then
        ok "AUR helper: paru $(paru --version 2>/dev/null | head -1 | awk '{print $2}' || echo '')"
    elif command -v yay >/dev/null 2>&1; then
        ok "AUR helper: yay"
    else
        warn "No AUR helper found (paru or yay)"
        hint "Install paru: git clone https://aur.archlinux.org/paru.git && cd paru && makepkg -si"
    fi
}

check_gamemode() {
    if command -v gamemoded >/dev/null 2>&1; then
        ok "GameMode installed"
        if systemctl --user is-active --quiet gamemoded 2>/dev/null || \
           systemctl is-active --quiet gamemoded 2>/dev/null; then
            ok "gamemoded is running"
        else
            ok "gamemoded is available (D-Bus activated on demand)"
        fi
    else
        warn "GameMode not installed"
        hint "sudo pacman -S gamemode lib32-gamemode"
    fi
}

check_mangohud() {
    if command -v mangohud >/dev/null 2>&1; then
        ok "MangoHud installed"
    else
        warn "MangoHud not installed"
        hint "sudo pacman -S mangohud lib32-mangohud"
    fi
}

check_nvidia_smi() {
    # Only run if NVIDIA GPU present
    if ! lspci 2>/dev/null | grep -qi nvidia; then return; fi
    if command -v nvidia-smi >/dev/null 2>&1; then
        local info
        info="$(nvidia-smi --query-gpu=name,driver_version --format=csv,noheader 2>/dev/null | head -1 || echo 'error')"
        ok "nvidia-smi: $info"
    else
        fail "nvidia-smi not found (nvidia-utils not installed?)"
        hint "sudo pacman -S nvidia-utils"
    fi
}

check_pipewire() {
    if systemctl --user is-active --quiet pipewire 2>/dev/null; then
        ok "PipeWire is running"
    else
        warn "PipeWire user service not active"
        hint "systemctl --user enable --now pipewire pipewire-pulse wireplumber"
    fi
    if systemctl --user is-active --quiet wireplumber 2>/dev/null; then
        ok "WirePlumber (session manager) is running"
    else
        warn "WirePlumber is not active"
        hint "systemctl --user enable --now wireplumber"
    fi
}

check_xdg_portal() {
    if command -v /usr/lib/xdg-desktop-portal-hyprland >/dev/null 2>&1 || \
       [[ -f /usr/lib/xdg-desktop-portal-hyprland ]]; then
        ok "xdg-desktop-portal-hyprland installed"
    else
        warn "xdg-desktop-portal-hyprland not found"
        hint "sudo pacman -S xdg-desktop-portal-hyprland"
    fi
    if systemctl --user is-active --quiet xdg-desktop-portal 2>/dev/null; then
        ok "xdg-desktop-portal running"
    else
        warn "xdg-desktop-portal not running"
        hint "systemctl --user enable --now xdg-desktop-portal"
    fi
}

check_bluetooth() {
    if systemctl is-active --quiet bluetooth 2>/dev/null; then
        ok "Bluetooth service running"
    else
        warn "Bluetooth service not active"
        hint "sudo systemctl enable --now bluetooth"
    fi
}

check_swap() {
    local swap_kb
    swap_kb=$(free | awk '/^Swap:/{print $2}')
    if (( swap_kb > 0 )); then
        local swap_gb=$(( swap_kb / 1024 / 1024 ))
        ok "Swap available: ${swap_gb} GB"
    else
        warn "No swap configured (hibernate unavailable; low-RAM systems may OOM)"
        hint "Consider: sudo systemctl enable systemd-swap  or add a swapfile"
    fi
}

check_wayland_env() {
    local ok_count=0
    for var in WAYLAND_DISPLAY XDG_SESSION_TYPE XDG_CURRENT_DESKTOP; do
        if [[ -n "${!var:-}" ]]; then
            (( ok_count++ ))
        fi
    done
    if (( ok_count == 3 )); then
        ok "Wayland session variables set (WAYLAND_DISPLAY, XDG_SESSION_TYPE, XDG_CURRENT_DESKTOP)"
    else
        warn "Some Wayland session variables are missing"
        hint "Ensure you are running inside a Hyprland session"
    fi
}

check_hyprlock() {
    if command -v hyprlock >/dev/null 2>&1; then
        local ver
        ver="$(hyprlock --version 2>/dev/null | head -1 || echo 'unknown')"
        ok "hyprlock installed: $ver"
    else
        fail "hyprlock not found"
        hint "sudo pacman -S hyprlock  # or: paru -S hyprlock-git"
    fi
}

check_systemd_resolved() {
    if systemctl is-active --quiet systemd-resolved 2>/dev/null; then
        ok "systemd-resolved (DNS) is running"
    else
        warn "systemd-resolved is not active"
        hint "sudo systemctl enable --now systemd-resolved"
    fi
}

# ── run all checks ────────────────────────────────────────────────────────────

header

printf "${W}  Core tools${N}\n"
check_cmd hyprctl    "Hyprland CLI (hyprctl)"
check_cmd nmcli      "NetworkManager CLI (nmcli)"
check_cmd pacman     "pacman package manager"
check_cmd python3    "Python 3"
check_cmd git        "Git"
check_cmd zsh        "Zsh shell"
check_cmd starship   "Starship prompt"
check_cmd fastfetch  "fastfetch (system info)"
check_cmd tmux       "tmux terminal multiplexer"
check_cmd nvim       "Neovim"
echo

printf "${W}  TorrentOS components${N}\n"
check_file /etc/torrentos/version           "Version file"
check_file /etc/torrentos/default-settings.toml "Default settings"
check_file /usr/share/torrentos-settings/torrentos_settings/__init__.py \
    "torrentos-settings Python package" \
    "sudo pacman -S torrentos-settings"
check_file /usr/bin/torrentos-first-boot-wizard "first-boot wizard"
check_file /usr/local/bin/torrentos-update-gui "update GUI launcher"
check_settings_file
echo

printf "${W}  Services${N}\n"
check_service_active NetworkManager "NetworkManager"
check_systemd_resolved
check_user_service   torrentos-settingsd "torrentos-settingsd"
check_failed_units
echo

printf "${W}  Hardware${N}\n"
check_internet
check_disk_space
check_swap
check_gpu
check_audio
check_hyprland_socket
echo

check_nvidia
check_nvidia_smi

printf "${W}  Session${N}\n"
check_wayland_env
check_xdg_portal
check_pipewire
check_bluetooth
echo

printf "${W}  Pacman & AUR${N}\n"
check_pacman_lock
check_writable "$HOME/.config" "~/.config"
check_aur_helper
echo

printf "${W}  Extra tools${N}\n"
check_flatpak
check_hyprlock
check_gamemode
check_mangohud
check_cmd libinput-gestures-setup "libinput-gestures (touchpad gestures)" \
    "sudo pacman -S libinput-gestures && libinput-gestures-setup start"
check_cmd wf-recorder "wf-recorder (screen recording)" "sudo pacman -S wf-recorder"
check_cmd git-delta   "git-delta (better diffs)"       "sudo pacman -S git-delta"
echo

# ── summary ───────────────────────────────────────────────────────────────────

total=$(( PASS + WARN + FAIL ))
printf "${D}  ─────────────────────────────────────────────────${N}\n"
printf "  ${G}✔ %d passed${N}  " "$PASS"
if (( WARN > 0 )); then printf "${Y}⚠ %d warning(s)${N}  " "$WARN"; fi
if (( FAIL > 0 )); then printf "${R}✘ %d failed${N}"      "$FAIL"; fi
echo
echo

# ── --fix suggestions ─────────────────────────────────────────────────────────
if [[ $FIX -eq 1 ]] && (( FAIL > 0 || WARN > 0 )); then
    printf "${W}  Suggested fixes:${N}\n"
    printf "${D}  ─────────────────────────────────────────────────${N}\n"

    # AUR helper missing
    if ! command -v paru >/dev/null 2>&1 && ! command -v yay >/dev/null 2>&1; then
        printf "${Y}  AUR helper:${N}\n"
        printf "${D}    git clone https://aur.archlinux.org/paru.git${N}\n"
        printf "${D}    cd paru && makepkg -si${N}\n"
    fi

    # flatpak / flathub
    if ! command -v flatpak >/dev/null 2>&1; then
        printf "${Y}  Install flatpak:${N}\n"
        printf "${D}    sudo pacman -S flatpak${N}\n"
    elif ! flatpak remotes 2>/dev/null | grep -q flathub; then
        printf "${Y}  Add Flathub remote:${N}\n"
        printf "${D}    flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo${N}\n"
    fi

    # hyprlock missing
    if ! command -v hyprlock >/dev/null 2>&1; then
        printf "${Y}  Install hyprlock:${N}\n"
        printf "${D}    sudo pacman -S hyprlock${N}\n"
    fi

    # systemd-resolved
    if ! systemctl is-active --quiet systemd-resolved 2>/dev/null; then
        printf "${Y}  Enable DNS resolver:${N}\n"
        printf "${D}    sudo systemctl enable --now systemd-resolved${N}\n"
        printf "${D}    sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf${N}\n"
    fi

    # pacman DB lock
    if [[ -f /var/lib/pacman/db.lck ]]; then
        printf "${Y}  Remove stale pacman lock:${N}\n"
        printf "${D}    sudo rm /var/lib/pacman/db.lck${N}\n"
    fi

    # audio / pipewire
    if ! (command -v pactl >/dev/null 2>&1 && pactl info >/dev/null 2>&1); then
        printf "${Y}  Restart audio:${N}\n"
        printf "${D}    systemctl --user restart pipewire pipewire-pulse wireplumber${N}\n"
    fi

    # bluetooth
    if ! systemctl is-active --quiet bluetooth 2>/dev/null; then
        printf "${Y}  Enable Bluetooth:${N}\n"
        printf "${D}    sudo systemctl enable --now bluetooth${N}\n"
    fi

    # xdg-desktop-portal
    if ! systemctl --user is-active --quiet xdg-desktop-portal 2>/dev/null; then
        printf "${Y}  Start XDG portal:${N}\n"
        printf "${D}    systemctl --user enable --now xdg-desktop-portal xdg-desktop-portal-hyprland${N}\n"
    fi

    # gamemode / mangohud
    if ! command -v gamemoded >/dev/null 2>&1; then
        printf "${Y}  Install GameMode:${N}\n"
        printf "${D}    sudo pacman -S gamemode lib32-gamemode${N}\n"
    fi

    echo
fi

if (( FAIL > 0 )); then
    exit 2
elif (( WARN > 0 )); then
    exit 1
fi
exit 0