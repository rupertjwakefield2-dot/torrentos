#!/usr/bin/env bash
# torrentos-get-browser — Install a web browser on TorrentOS
# Can be run from a terminal, the app launcher, or the first-boot wizard.
# Usage: torrentos-get-browser [--quiet]

set -euo pipefail

B='\033[38;2;30;111;255m'
C='\033[38;2;91;192;235m'
G='\033[38;2;91;235;161m'
Y='\033[38;2;255;180;84m'
R='\033[38;2;255;107;107m'
W='\033[1;37m'
D='\033[2;37m'
N='\033[0m'
HR="${D}  ─────────────────────────────────────────────────────────${N}"

# Fix terminal state
stty sane 2>/dev/null || true

# ── check AUR helper ──────────────────────────────────────────────────────────
if command -v paru >/dev/null 2>&1; then
    AUR=paru
elif command -v yay >/dev/null 2>&1; then
    AUR=yay
else
    AUR=""
fi

# ── header ────────────────────────────────────────────────────────────────────
clear
echo
printf "${B}  TorrentOS — Browser Installer${N}\n"
echo "$HR"
echo
printf "${D}  Choose a browser to install. Chromium is already included${N}\n"
printf "${D}  with TorrentOS — the others take 1–3 minutes to install.${N}\n"
echo

# ── browser menu ──────────────────────────────────────────────────────────────
printf "  ${W}1)${N}  ${C}Google Chrome${N}       ${D}The most popular browser. Syncs with your Google account.${N}\n"
printf "  ${W}2)${N}  ${C}Firefox${N}             ${D}Fast, private, open-source. Best for privacy.${N}\n"
printf "  ${W}3)${N}  ${C}Brave${N}               ${D}Chrome-based with built-in ad blocking.${N}\n"
printf "  ${W}4)${N}  ${C}Vivaldi${N}             ${D}Chrome-based, highly customisable.${N}\n"
printf "  ${W}5)${N}  ${C}Microsoft Edge${N}      ${D}Chrome-based, integrates with Microsoft 365.${N}\n"
printf "  ${W}6)${N}  ${C}Chromium${N}            ${D}Already installed — open-source Chrome (no Google account sync).${N}\n"
printf "  ${W}7)${N}  ${C}All of the above${N}    ${D}Install everything listed.${N}\n"
printf "  ${W}8)${N}  ${C}Skip / exit${N}\n"
echo

printf "${W}  Your choice [1]: ${N}"
read -r CHOICE
CHOICE="${CHOICE:-1}"

# ── install function ──────────────────────────────────────────────────────────
install_browser() {
    local name="$1" pkg="$2" source="${3:-pacman}"  # source: pacman | aur | flatpak
    echo
    printf "${B}  Installing ${W}${name}${N}${B}...${N}\n"
    echo "$HR"

    case "$source" in
        pacman)
            sudo pacman -S --needed --noconfirm "$pkg" && \
                printf "${G}  ✔  ${name} installed.${N}\n" || \
                printf "${R}  ✘  Failed to install ${name} via pacman.${N}\n"
            ;;
        aur)
            if [[ -z "$AUR" ]]; then
                printf "${Y}  ⚠  No AUR helper found. Installing paru first…${N}\n"
                tmpdir="$(mktemp -d)"
                git clone --depth=1 https://aur.archlinux.org/paru-bin.git "$tmpdir/paru-bin" 2>/dev/null
                pushd "$tmpdir/paru-bin" >/dev/null
                makepkg -si --noconfirm --skipchecksums --skippgpcheck
                popd >/dev/null
                rm -rf "$tmpdir"
                AUR=paru
            fi
            "$AUR" -S --needed --noconfirm "$pkg" && \
                printf "${G}  ✔  ${name} installed.${N}\n" || \
                printf "${R}  ✘  Failed to install ${name}. Try: ${AUR} -S ${pkg}${N}\n"
            ;;
        flatpak)
            if ! command -v flatpak >/dev/null 2>&1; then
                sudo pacman -S --needed --noconfirm flatpak
            fi
            flatpak install --noninteractive flathub "$pkg" && \
                printf "${G}  ✔  ${name} installed.${N}\n" || \
                printf "${R}  ✘  Failed to install ${name} via Flatpak.${N}\n"
            ;;
    esac
}

# ── dispatch ──────────────────────────────────────────────────────────────────
case "$CHOICE" in
    1) install_browser "Google Chrome"    "google-chrome"                aur     ;;
    2) install_browser "Firefox"          "firefox"                      pacman  ;;
    3) install_browser "Brave"            "brave-bin"                    aur     ;;
    4) install_browser "Vivaldi"          "vivaldi"                      aur     ;;
    5) install_browser "Microsoft Edge"   "microsoft-edge-stable-bin"    aur     ;;
    6) printf "${G}  ✔  Chromium is already installed — open it from the app launcher.${N}\n" ;;
    7)
        install_browser "Google Chrome"   "google-chrome"                aur
        install_browser "Firefox"         "firefox"                      pacman
        install_browser "Brave"           "brave-bin"                    aur
        install_browser "Vivaldi"         "vivaldi"                      aur
        install_browser "Microsoft Edge"  "microsoft-edge-stable-bin"    aur
        ;;
    8) echo; printf "${D}  Skipped.${N}\n"; exit 0 ;;
    *) echo; printf "${Y}  Unknown choice. Run torrentos-get-browser to try again.${N}\n"; exit 1 ;;
esac

# ── post-install tip ──────────────────────────────────────────────────────────
echo
echo "$HR"
printf "${G}  Done!${N} ${D}Press ${W}Super + Space${D} to open the app launcher and search for your browser.${N}\n"
printf "${D}  Or run: ${W}google-chrome${D}, ${W}firefox${D}, ${W}brave${D} etc. from the terminal.${N}\n"
echo
