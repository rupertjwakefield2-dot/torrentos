#!/usr/bin/env bash
# TorrentOS — interactive help & reference viewer
# Usage: torrentos-help [topic]
# Topics: keys, aliases, apps, update, wifi, install

set -euo pipefail

B='\033[38;2;30;111;255m'    # blue
C='\033[38;2;91;192;235m'    # cyan
G='\033[38;2;91;235;161m'    # green
Y='\033[38;2;255;180;84m'    # yellow
W='\033[1;37m'               # white
D='\033[2;37m'               # dim
R='\033[38;2;255;107;107m'   # red
N='\033[0m'                  # reset

HR="${D}  ─────────────────────────────────────────────────────────${N}"

header() {
    echo
    local _ver; _ver="$(grep '^TORRENTOS_VERSION=' /etc/torrentos/version 2>/dev/null | cut -d= -f2 | tr -d '"' || echo 0.5)"
    printf "${B}  TorrentOS v${_ver} — $1${N}\n"
    echo "$HR"
    echo
}

topic_keys() {
    header "Keyboard shortcuts"
    printf "${C}  Desktop${N}\n"
    printf "${D}  %-30s${N} %s\n" "Super + Space"       "App launcher (Spotlight)"
    printf "${D}  %-30s${N} %s\n" "Super + Return"      "Open terminal"
    printf "${D}  %-30s${N} %s\n" "Super + Shift + Return" "Floating terminal"
    printf "${D}  %-30s${N} %s\n" "Super + E"           "File manager"
    printf "${D}  %-30s${N} %s\n" "Super + B"           "Browser"
    printf "${D}  %-30s${N} %s\n" "Super + T"           "Torrents"
    printf "${D}  %-30s${N} %s\n" "Super + C"           "Code editor (VS Code)"
    printf "${D}  %-30s${N} %s\n" "Super + U"           "System update GUI"
    printf "${D}  %-30s${N} %s\n" "Super + comma"       "Settings"
    printf "${D}  %-30s${N} %s\n" "Super + equal"       "Magnifier (Magnus) toggle"
    printf "${D}  %-30s${N} %s\n" "Super + L"           "Lock screen"
    printf "${D}  %-30s${N} %s\n" "Super + Ctrl + Q"    "Power menu"
    printf "${D}  %-30s${N} %s\n" "Super + Q"           "Close window"
    printf "${D}  %-30s${N} %s\n" "Super + F"           "Fullscreen"
    printf "${D}  %-30s${N} %s\n" "Super + Shift + F"   "Float / tile toggle"
    printf "${D}  %-30s${N} %s\n" "Super + Tab"         "Window switcher"
    echo
    printf "${C}  Workspaces${N}\n"
    printf "${D}  %-30s${N} %s\n" "Super + 1–9"         "Switch to workspace"
    printf "${D}  %-30s${N} %s\n" "Super + Shift + 1–9" "Move window to workspace"
    printf "${D}  %-30s${N} %s\n" "Super + \`"          "Scratchpad"
    printf "${D}  %-30s${N} %s\n" "3-finger swipe"      "Swipe between workspaces"
    echo
    printf "${C}  Screenshots${N}\n"
    printf "${D}  %-30s${N} %s\n" "Print"               "Full screen → clipboard"
    printf "${D}  %-30s${N} %s\n" "Shift + Print"       "Region → clipboard"
    printf "${D}  %-30s${N} %s\n" "Super + Print"       "Full screen → ~/Pictures/Screenshots"
    printf "${D}  %-30s${N} %s\n" "Super + Shift + S"   "Region → save + clipboard"
    printf "${D}  %-30s${N} %s\n" "Super + Ctrl + S"    "Screenshot GUI (mode/delay/preview)"
    printf "${D}  %-30s${N} %s\n" "Super + P"           "Colour picker (hyprpicker)"
    echo
    printf "${C}  Focus & layout${N}\n"
    printf "${D}  %-30s${N} %s\n" "Super + H/J/K/L"     "Move focus (vim-style)"
    printf "${D}  %-30s${N} %s\n" "Super + Shift + H/J/K/L" "Move window"
    printf "${D}  %-30s${N} %s\n" "Super + Ctrl + H/J/K/L"  "Resize window"
    echo
}

topic_aliases() {
    header "Terminal aliases"
    printf "${C}  Files${N}\n"
    printf "${D}  %-18s${N} %s\n" "ls"        "eza with icons"
    printf "${D}  %-18s${N} %s\n" "ll"        "Long listing with git status"
    printf "${D}  %-18s${N} %s\n" "la"        "Long listing + hidden files"
    printf "${D}  %-18s${N} %s\n" "lt"        "Tree view (2 levels)"
    printf "${D}  %-18s${N} %s\n" "cat"       "bat with syntax highlighting"
    printf "${D}  %-18s${N} %s\n" "less"      "bat pager"
    echo
    printf "${C}  System${N}\n"
    printf "${D}  %-18s${N} %s\n" "update"    "Update all packages"
    printf "${D}  %-18s${N} %s\n" "top/htop"  "btop system monitor"
    printf "${D}  %-18s${N} %s\n" "settings"  "Open TorrentOS Settings"
    printf "${D}  %-18s${N} %s\n" "files"     "Open file manager"
    printf "${D}  %-18s${N} %s\n" "browser"   "Open Firefox"
    printf "${D}  %-18s${N} %s\n" "myip"      "Show public IP"
    echo
    printf "${C}  Clipboard${N}\n"
    printf "${D}  %-18s${N} %s\n" "pbcopy"    "Copy stdin to clipboard"
    printf "${D}  %-18s${N} %s\n" "pbpaste"   "Paste clipboard to stdout"
    echo
    printf "${C}  Git${N}\n"
    printf "${D}  %-18s${N} %s\n" "g"         "git"
    printf "${D}  %-18s${N} %s\n" "gs"        "git status"
    printf "${D}  %-18s${N} %s\n" "gd"        "git diff"
    printf "${D}  %-18s${N} %s\n" "gl"        "git log --oneline --graph"
    echo
    printf "${C}  Dev${N}\n"
    printf "${D}  %-18s${N} %s\n" "dc"        "docker compose"
    printf "${D}  %-18s${N} %s\n" "k"         "kubectl"
    echo
    printf "${C}  TorrentOS${N}\n"
    printf "${D}  %-18s${N} %s\n" "doctor"    "System health check (torrentos-doctor)"
    printf "${D}  %-18s${N} %s\n" "help"      "This help viewer"
    echo
}

topic_wifi() {
    header "WiFi management"
    printf "${C}  Scan & connect${N}\n"
    printf "${D}  %-40s${N}\n  %s\n\n" "List available networks:" "nmcli dev wifi list"
    printf "${D}  %-40s${N}\n  %s\n\n" "Connect to a network:" "nmcli dev wifi connect 'SSID' password 'PASS'"
    printf "${D}  %-40s${N}\n  %s\n\n" "Show active connections:" "nmcli con show --active"
    printf "${D}  %-40s${N}\n  %s\n\n" "Disconnect:" "nmcli dev disconnect wlan0"
    echo
    printf "${C}  GUI tools${N}\n"
    printf "${D}  %-40s${N}\n  %s\n\n" "Graphical WiFi manager:" "nm-connection-editor"
    printf "${D}  %-40s${N}\n  %s\n\n" "Terminal WiFi menu:" "nmtui"
    echo
}

topic_update() {
    header "System updates"
    printf "${C}  GUI updater${N}\n"
    printf "${D}  %-40s${N}\n  %s\n\n" "Open the update GUI:" "torrentos-update-gui"
    printf "${C}  Terminal upgrade${N}\n"
    printf "${D}  %s${N}\n\n"  "  update"
    printf "${D}  or manually:${N}\n"
    printf "${D}  %s${N}\n\n"  "  sudo pacman -Syu"
    echo
    printf "${C}  Install a package${N}\n"
    printf "${D}  %s${N}\n\n"  "  sudo pacman -S <package>"
    printf "${D}  or (with AUR):${N}\n"
    printf "${D}  %s${N}\n\n"  "  paru -S <package>"
    echo
    printf "${C}  Search for a package${N}\n"
    printf "${D}  %s${N}\n\n"  "  pacman -Ss <keyword>"
    echo
    printf "${C}  Remove a package${N}\n"
    printf "${D}  %s${N}\n\n"  "  sudo pacman -Rns <package>"
    echo
}

topic_install() {
    header "Installing TorrentOS to disk"
    printf "  ${Y}This will permanently erase the target disk.${N}\n"
    printf "  Make sure you have backed up your data first.\n\n"
    printf "${C}  Graphical installer${N}\n"
    printf "${D}  Click the install icon on the dock, or run:${N}\n"
    printf "${D}  %s${N}\n\n"  "  torrentos-install-gui"
    printf "${C}  Terminal installer${N}\n"
    printf "${D}  %s${N}\n\n"  "  sudo torrentos-install"
    echo
    printf "${D}  Both launchers use archinstall with TorrentOS defaults.${N}\n"
    printf "${D}  An internet connection is required.${N}\n\n"
}

topic_apps() {
    header "Pre-installed applications"
    printf "${C}  Internet${N}\n"
    printf "${D}  %-24s${N} %s\n" "Firefox"          "Web browser"
    printf "${D}  %-24s${N} %s\n" "qBittorrent"      "BitTorrent client"
    printf "${D}  %-24s${N} %s\n" "nm-connection-editor" "Network manager"
    echo
    printf "${C}  Development${N}\n"
    printf "${D}  %-24s${N} %s\n" "Visual Studio Code"  "Code editor"
    printf "${D}  %-24s${N} %s\n" "Ghostty"             "GPU-accelerated terminal"
    printf "${D}  %-24s${N} %s\n" "Git"                 "Version control"
    printf "${D}  %-24s${N} %s\n" "Docker"              "Container runtime"
    echo
    printf "${C}  System${N}\n"
    printf "${D}  %-24s${N} %s\n" "Nautilus"           "File manager"
    printf "${D}  %-24s${N} %s\n" "TorrentOS Settings" "System preferences (Super+,)"
    printf "${D}  %-24s${N} %s\n" "Screenshot tool"    "Region/full/window capture (Super+Ctrl+S)"
    printf "${D}  %-24s${N} %s\n" "System Update"      "torrentos-update-gui  (Super+U)"
    printf "${D}  %-24s${N} %s\n" "Doctor"             "torrentos-doctor  (health check)"
    printf "${D}  %-24s${N} %s\n" "Magnus"             "Pixel magnifier  (Super+=)"
    printf "${D}  %-24s${N} %s\n" "btop"               "System monitor"
    printf "${D}  %-24s${N} %s\n" "pavucontrol"        "Audio mixer"
    printf "${D}  %-24s${N} %s\n" "blueman"            "Bluetooth manager"
    echo
    printf "${C}  Media${N}\n"
    printf "${D}  %-24s${N} %s\n" "mpv"             "Video/audio player"
    printf "${D}  %-24s${N} %s\n" "Loupe"           "Image viewer"
    echo
}

topic_main() {
    header "Help topics"
    printf "${C}  Usage: torrentos-help <topic>${N}\n\n"
    printf "${D}  %-12s${N} %s\n" "keys"    "Keyboard shortcuts"
    printf "${D}  %-12s${N} %s\n" "aliases" "Terminal command aliases"
    printf "${D}  %-12s${N} %s\n" "apps"    "Pre-installed applications"
    printf "${D}  %-12s${N} %s\n" "wifi"    "WiFi / networking commands"
    printf "${D}  %-12s${N} %s\n" "update"  "Package management"
    printf "${D}  %-12s${N} %s\n" "install" "Install TorrentOS to disk"
    echo
    printf "${D}  Site: ${W}torrentos.org${N}  ·  Source: ${W}github.com/rupertjwakefield2-dot/torrentos${N}\n"
    echo
}

# ── Dispatch ─────────────────────────────────────────────────────────────────
case "${1:-}" in
    keys|key|k)         topic_keys ;;
    aliases|alias|a)    topic_aliases ;;
    wifi|network|net|n) topic_wifi ;;
    update|upgrade|u)   topic_update ;;
    install|i)          topic_install ;;
    apps|app)           topic_apps ;;
    ""|help|-h|--help)  topic_main ;;
    *)
        printf "${R}  Unknown topic: $1${N}\n"
        topic_main
        exit 1
        ;;
esac
