# Maintainer: TorrentOS <packages@torrentos.org>
pkgname=torrentos-tools
pkgver=0.5.0
pkgrel=1
pkgdesc="TorrentOS GUI tools: screenshot, system update, help reference, update notifier, health check, and browser installer"
arch=('any')
url="https://torrentos.org"
license=('GPL3')
depends=(
    'python'
    'python-gobject'
    'gtk4'
    'libadwaita'
    'vte4'          # VTE terminal widget for update GUI
    'grim'          # screenshot backend
    'slurp'         # region selection for screenshots
    'wl-clipboard'  # wl-copy / wl-paste
    'pacman'        # paru/pacman for update runner
)
optdepends=(
    'paru: AUR helper used by system update and update notifier'
    'pacman-contrib: checkupdates (used by update notifier)'
    'loupe: image viewer for screenshot preview'
    'libnotify: desktop notifications (screenshots, update notifier)'
    'hyprctl: window geometry for window-mode screenshot'
    'archinstall: guided installer used by torrentos-install'
    'jq: JSON processing used by torrentos-install'
)
source=(
    'torrentos-update-gui'
    'torrentos-update-gui.desktop'
    'torrentos-screenshot'
    'torrentos-screenshot.desktop'
    'torrentos-help'
    'torrentos-help.desktop'
    'torrentos-update-check'
    'torrentos-doctor'
    'torrentos-get-browser'
    'torrentos-get-browser.desktop'
    'torrentos-install'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    # Executables
    install -Dm755 "$srcdir/torrentos-update-gui"      "$pkgdir/usr/local/bin/torrentos-update-gui"
    install -Dm755 "$srcdir/torrentos-screenshot"      "$pkgdir/usr/local/bin/torrentos-screenshot"
    install -Dm755 "$srcdir/torrentos-help"            "$pkgdir/usr/local/bin/torrentos-help"
    install -Dm755 "$srcdir/torrentos-update-check"    "$pkgdir/usr/local/bin/torrentos-update-check"
    install -Dm755 "$srcdir/torrentos-doctor"          "$pkgdir/usr/local/bin/torrentos-doctor"
    install -Dm755 "$srcdir/torrentos-get-browser"     "$pkgdir/usr/local/bin/torrentos-get-browser"

    install -Dm755 "$srcdir/torrentos-install"           "$pkgdir/usr/local/bin/torrentos-install"

    # Desktop entries
    install -Dm644 "$srcdir/torrentos-update-gui.desktop"  \
        "$pkgdir/usr/share/applications/torrentos-update.desktop"
    install -Dm644 "$srcdir/torrentos-screenshot.desktop"  \
        "$pkgdir/usr/share/applications/torrentos-screenshot.desktop"
    install -Dm644 "$srcdir/torrentos-help.desktop"        \
        "$pkgdir/usr/share/applications/torrentos-help.desktop"
    install -Dm644 "$srcdir/torrentos-get-browser.desktop" \
        "$pkgdir/usr/share/applications/torrentos-get-browser.desktop"
}
