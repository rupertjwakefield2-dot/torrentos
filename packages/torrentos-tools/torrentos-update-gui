#!/usr/bin/env python3
"""TorrentOS Update — GTK4/libadwaita GUI that runs a system update with live output."""

import gi
import subprocess
import threading
import sys

gi.require_version("Gtk",  "4.0")
gi.require_version("Adw",  "1")
gi.require_version("Vte",  "3.91")

from gi.repository import Gtk, Adw, GLib, Pango

# ── Fallback: no VTE → show simple progress dialog ───────────────────────────
try:
    from gi.repository import Vte
    HAS_VTE = True
except Exception:
    HAS_VTE = False


UPDATE_CMD = ["bash", "-c",
    "set -euo pipefail; "
    "echo ':: Syncing package databases…'; "
    "if command -v paru >/dev/null 2>&1; then "
    "    paru -Syu --noconfirm 2>&1; "
    "else "
    "    sudo pacman -Syu --noconfirm 2>&1; "
    "fi; "
    "echo; echo ':: Update complete.'"
]

CHECK_CMD = ["bash", "-c",
    "echo ':: Checking for updates…'; "
    "echo; "
    "HAS=0; "
    "if command -v checkupdates >/dev/null 2>&1; then "
    "    PKGS=$(checkupdates 2>/dev/null || true); "
    "    if [ -n \"$PKGS\" ]; then "
    "        echo \"  Pacman updates:\"; "
    "        echo \"$PKGS\" | awk '{printf \"  %-30s %s → %s\\n\", $1, $2, $4}'; "
    "        HAS=1; "
    "    else "
    "        echo '  ✓ All pacman packages are up to date.'; "
    "    fi; "
    "fi; "
    "if command -v paru >/dev/null 2>&1; then "
    "    echo; "
    "    AUR=$(paru -Qua 2>/dev/null || true); "
    "    if [ -n \"$AUR\" ]; then "
    "        echo '  AUR updates:'; "
    "        echo \"$AUR\" | awk '{printf \"  %-30s %s → %s\\n\", $1, $2, $4}'; "
    "        HAS=1; "
    "    else "
    "        echo '  ✓ All AUR packages are up to date.'; "
    "    fi; "
    "fi; "
    "echo; "
    "if [ $HAS -eq 0 ]; then "
    "    echo '  ✓ Your system is fully up to date.'; "
    "fi"
]


class UpdateWindow(Adw.ApplicationWindow):
    def __init__(self, app, check_only: bool = False):
        super().__init__(application=app, title="System Update")
        self.set_default_size(720, 520)
        self.set_resizable(True)
        self._done = False
        self._check_only = check_only

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.set_content(box)

        # Header
        header = Adw.HeaderBar()
        header.add_css_class("flat")

        # "Update Now" button (only shown when in check-only mode, after check)
        self._update_now_btn = Gtk.Button(label="Update Now")
        self._update_now_btn.add_css_class("suggested-action")
        self._update_now_btn.set_visible(False)
        self._update_now_btn.connect("clicked", self._run_update_now)
        header.pack_end(self._update_now_btn)

        box.append(header)

        # Status banner
        self._banner = Adw.Banner()
        self._banner.set_title("Checking for updates…" if check_only else "Updating your system…")
        self._banner.set_revealed(True)
        box.append(self._banner)

        # Progress bar
        self._progress = Gtk.ProgressBar()
        self._progress.set_pulse_step(0.04)
        self._progress.set_margin_start(16)
        self._progress.set_margin_end(16)
        self._progress.set_margin_top(8)
        self._progress.set_margin_bottom(8)
        self._progress.add_css_class("osd")
        box.append(self._progress)

        # Terminal or text view
        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        box.append(scroll)

        if HAS_VTE:
            self._term = Vte.Terminal()
            self._term.set_font(Pango.FontDescription.from_string("JetBrainsMono Nerd Font 11"))
            self._term.set_scrollback_lines(10000)
            self._term.set_audible_bell(False)
            # TorrentOS colour palette
            from gi.repository import Gdk
            def c(r, g, b): rgba = Gdk.RGBA(); rgba.red=r/255; rgba.green=g/255; rgba.blue=b/255; rgba.alpha=1; return rgba
            self._term.set_color_background(c(7, 15, 29))
            self._term.set_color_foreground(c(244, 247, 251))
            palette = [
                c(10,22,40), c(255,107,107), c(91,192,235), c(255,180,84),
                c(30,111,255), c(198,120,221), c(91,192,235), c(244,247,251),
                c(59,66,82), c(255,133,133), c(122,211,242), c(255,204,128),
                c(92,139,255), c(215,161,229), c(122,211,242), c(255,255,255),
            ]
            self._term.set_colors(c(244,247,251), c(7,15,29), palette)
            scroll.set_child(self._term)
            self._use_vte = True
        else:
            self._buf = Gtk.TextBuffer()
            tv = Gtk.TextView(buffer=self._buf)
            tv.set_editable(False)
            tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
            tv.set_monospace(True)
            tv.add_css_class("terminal")
            scroll.set_child(tv)
            self._tv = tv
            self._use_vte = False

        # Bottom action bar
        action_bar = Gtk.ActionBar()
        box.append(action_bar)

        self._status_label = Gtk.Label(label="Starting…")
        self._status_label.add_css_class("caption")
        self._status_label.add_css_class("dim-label")
        action_bar.pack_start(self._status_label)

        self._close_btn = Gtk.Button(label="Close")
        self._close_btn.set_sensitive(False)
        self._close_btn.connect("clicked", lambda _: self.close())
        action_bar.pack_end(self._close_btn)

        self._reboot_btn = Gtk.Button(label="Reboot Now")
        self._reboot_btn.add_css_class("destructive-action")
        self._reboot_btn.set_sensitive(False)
        self._reboot_btn.connect("clicked", self._reboot)
        action_bar.pack_end(self._reboot_btn)

        self.present()
        self._start_update(check_only=check_only)

    def _start_update(self, check_only: bool = False):
        cmd = CHECK_CMD if check_only else UPDATE_CMD
        self._pulse_id = GLib.timeout_add(80, self._pulse)
        if self._use_vte:
            # child-exited fires with the waitpid status when the process ends
            self._term.connect("child-exited", self._on_child_exited)
            self._term.spawn_async(
                Vte.PtyFlags.DEFAULT,
                None, cmd, [],
                GLib.SpawnFlags.DO_NOT_REAP_CHILD,
                None, None, -1, None,
                self._on_vte_spawned, None,
            )
        else:
            t = threading.Thread(target=self._run_cmd, args=(cmd,), daemon=True)
            t.start()

    def _run_update_now(self, _btn):
        """Switch from check-only mode to actually running the update."""
        self._check_only = False
        self._done = False
        self._update_now_btn.set_visible(False)
        self._close_btn.set_sensitive(False)
        self._reboot_btn.set_sensitive(False)
        self._banner.set_title("Updating your system…")
        self._banner.remove_css_class("success")
        if self._use_vte:
            self._term.reset(True, True)
        else:
            self._buf.set_text("")
        self._start_update(check_only=False)

    def _on_vte_spawned(self, terminal, pid, err, user_data):
        """Called when the child process has been spawned (not when it exits).
        Only handle spawn failure here; normal completion is handled by child-exited."""
        if err is not None:
            GLib.idle_add(self._finish, False)

    def _on_child_exited(self, terminal, status):
        """Called when the update process actually exits."""
        import os
        try:
            exitcode = os.waitstatus_to_exitcode(status)
        except (AttributeError, ValueError):
            exitcode = (status >> 8) & 0xFF
        GLib.idle_add(self._finish, exitcode == 0)

    def _run_cmd(self, cmd: list):
        try:
            proc = subprocess.Popen(
                cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )
            for line in proc.stdout:
                GLib.idle_add(self._append_text, line)
            proc.wait()
            GLib.idle_add(self._finish, proc.returncode == 0)
        except Exception as e:
            GLib.idle_add(self._append_text, f"\nError: {e}\n")
            GLib.idle_add(self._finish, False)

    def _append_text(self, text):
        end = self._buf.get_end_iter()
        self._buf.insert(end, text)
        # Auto-scroll
        adj = self._tv.get_parent().get_vadjustment()
        adj.set_value(adj.get_upper() - adj.get_page_size())

    def _pulse(self):
        if self._done:
            return GLib.SOURCE_REMOVE
        self._progress.pulse()
        return GLib.SOURCE_CONTINUE

    def _finish(self, success: bool):
        self._done = True
        if hasattr(self, '_pulse_id'):
            GLib.source_remove(self._pulse_id)

        if self._check_only:
            self._progress.set_fraction(1.0)
            if success:
                self._banner.set_title("Update check complete.")
                self._banner.add_css_class("success")
                self._status_label.set_text("See results above.")
                self._update_now_btn.set_visible(True)
            else:
                self._banner.set_title("Check finished with errors.")
                self._banner.add_css_class("error")
                self._status_label.set_text("Check output above for details.")
        else:
            if success:
                self._progress.set_fraction(1.0)
                self._banner.set_title("Update complete.")
                self._status_label.set_text("System is up to date.")
                self._reboot_btn.set_sensitive(True)
            else:
                self._progress.set_fraction(0.0)
                self._banner.set_title("Update finished with errors.")
                self._banner.add_css_class("error")
                self._status_label.set_text("Check output above for details.")

        self._close_btn.set_sensitive(True)

    def _reboot(self, _btn):
        subprocess.Popen(["systemctl", "reboot"])


class UpdateApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.torrentos.Update")
        self.connect("activate", self._activate)

    def _activate(self, app):
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        # --check flag: show available updates without installing
        check_only = "--check" in sys.argv
        UpdateWindow(app, check_only=check_only)


if __name__ == "__main__":
    app = UpdateApp()
    sys.exit(app.run([a for a in sys.argv if a != "--check"]))
