# Maintainer: TorrentOS <packages@torrentos.org>
pkgname=torrentos-base
pkgver=0.5.0
pkgrel=1
pkgdesc="TorrentOS base meta-package — branding, version file, defaults, and core tools"
arch=('any')
url="https://torrentos.org"
license=('GPL3')
depends=(
    # Compositor & shell
    'hyprland'
    'waybar'
    'swaync'
    'rofi-wayland'
    'nwg-dock-hyprland'
    'hyprlock'
    'hypridle'
    'hyprpaper'
    'hyprpicker'
    'ghostty'
    # Networking
    'networkmanager'
    'network-manager-applet'
    'bluez'
    'bluez-utils'
    'blueman'
    # Audio
    'pipewire'
    'pipewire-pulse'
    'wireplumber'
    'pavucontrol'
    # Media / accessibility
    'playerctl'
    'orca'
    'at-spi2-core'
    # Screen capture & recording
    'grim'
    'slurp'
    'wl-clipboard'
    'cliphist'
    'wl-clip-persist'
    'wf-recorder'
    # Night light
    'gammastep'
    # System tools
    'flatpak'
    'brightnessctl'
    'xdg-utils'
    'xdg-user-dirs'
    'polkit-gnome'
    'libinput-gestures'   # touchpad gesture daemon
    # Shell & terminal tools
    'zsh'
    'zsh-completions'
    'starship'
    'fastfetch'
    'fzf'
    'ripgrep'
    'fd'
    'bat'
    'eza'
    'zoxide'
    'btop'
    'tmux'
    'jq'
    'expac'               # pkgsize alias in .zshrc
    # Editor
    'neovim'
    # Gaming
    'gamemode'
    'lib32-gamemode'
    'mangohud'
    'lib32-mangohud'
    # Developer tools
    'git-delta'           # better git diffs (.gitconfig pager)
    'strace'
    'lsof'
    'nmap'
    'socat'
    'zip'
    'tokei'               # code stats (loc counter)
    'hyperfine'           # benchmarking tool
    # Utilities
    'imv'                 # lightweight image viewer (CLI)
    'gnome-calculator'
    'gnome-font-viewer'
    # Qt / theming
    'qt6ct'
    'kvantum'
    # Fonts
    'inter-font'
    'papirus-icon-theme'
    'noto-fonts'
    'noto-fonts-emoji'
    'ttf-jetbrains-mono-nerd'
)
backup=(
    'etc/torrentos/default-settings.toml'
    'etc/torrentos/version'
)
source=(
    'version'
    'default-settings.toml'
    'os-release'
    'devmode'
    'settingsd'
    'firstboot'
    'torrentos-settingsd.service'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    install -Dm644 "$srcdir/version"               "$pkgdir/etc/torrentos/version"
    install -Dm644 "$srcdir/default-settings.toml" "$pkgdir/etc/torrentos/default-settings.toml"
    install -Dm644 "$srcdir/os-release"            "$pkgdir/usr/lib/os-release.torrentos"
    install -Dm755 "$srcdir/devmode"               "$pkgdir/usr/lib/torrentos/devmode"
    install -Dm755 "$srcdir/settingsd"             "$pkgdir/usr/lib/torrentos/settingsd"
    install -Dm755 "$srcdir/firstboot"             "$pkgdir/usr/local/bin/torrentos-firstboot"
    # Install as a USER unit (daemon runs per-user, needs access to ~/.config and hyprctl)
    install -Dm644 "$srcdir/torrentos-settingsd.service" \
        "$pkgdir/usr/lib/systemd/user/torrentos-settingsd.service"

    # Enable greetd at boot on installed system
    # (greetd config is owned by the 'greetd' package; the live ISO airootfs
    #  overlay applies our custom config on top after pacstrap.)
    install -dm755 "$pkgdir/usr/lib/systemd/system/multi-user.target.wants"
    ln -sf /usr/lib/systemd/system/greetd.service \
        "$pkgdir/usr/lib/systemd/system/multi-user.target.wants/greetd.service"
}
